# Environment Variables Template
# Copia este archivo a .env y completa los valores con tus credenciales reales

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Neon PostgreSQL Configuration
DATABASE_URL=postgresql://neondb_owner:your-password@your-neon-host.neon.tech/neondb?sslmode=require&channel_binding=require

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Application secret key (change this in production)
SECRET_KEY=your-secret-key-change-me-in-production

# Debug mode (true for development, false for production)
DEBUG=true

# ===========================================
# CLOUDINARY CONFIGURATION
# ===========================================

# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=d

# Cloudinary API key
CLOUDINARY_API_KEY=your-api-key-change-me

# Cloudinary API secret
CLOUDINARY_API_SECRET=your-api-secret-change-me

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:4321

# ===========================================
# DEPLOYMENT SETTINGS
# ===========================================

# Deployment environment (development/staging/production)
NODE_ENV=development
