# ── Dockerfile.dev — Desarrollo con hot-reload ─────────────
# Sin el RUN pnpm run build para evitar errores de Svelte 5
# en pre-renderizado. El dev corre con "pnpm dev" desde compose.
# ──────────────────────────────────────────────────────────────
FROM node:22-alpine

# Declare build-time variable
ARG PUBLIC_API_URL
ENV PUBLIC_API_URL=$PUBLIC_API_URL

# Install pnpm
RUN npm install -g pnpm

WORKDIR /app

# Copy lockfile and package manifest
COPY package.json pnpm-lock.yaml ./

# Install dependencies (--ignore-scripts porque el host global lo tiene)
# NOTA: sin --frozen-lockfile porque es Dockerfile.dev, los locks pueden diferir
RUN pnpm install --ignore-scripts

# Copy the rest of the source code
COPY . .

EXPOSE 4321

ENV HOST=0.0.0.0
ENV PORT=4321
ENV NODE_ENV=development

# Default command (overridden by compose)
CMD ["pnpm", "dev"]
