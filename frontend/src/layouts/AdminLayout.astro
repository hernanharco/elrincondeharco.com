---
import '../styles/global.css';
import AdminSidebar from '../components/layout/AdminSidebar.svelte';

interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = '' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-[Inter]">
    <div class="flex min-h-screen">
      <!-- Sidebar: client:load para interactividad inmediata -->
      <AdminSidebar client:load currentPath={currentPath} />

      <!-- Contenido principal -->
      <main class="flex-1 p-6 md:p-10 transition-all duration-300">
        <slot />
      </main>
    </div>
  </body>
</html>
