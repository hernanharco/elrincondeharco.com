---
import '../styles/global.css';
import Hero3DBackground from '../components/effects/Hero3DBackground.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hernan Arango Cortes - Full Stack Developer',
  description = 'Portfolio de Hernan Arango Cortes. Desarrollador Full Stack con 14+ años de experiencia.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
		</noscript>

		<style>
			html { scroll-behavior: smooth; }
			body { background: #060606; }
		</style>
	</head>
	<body class="font-[Inter] text-white">
		<!-- 3D Background - persiste en todo el sitio -->
		<Hero3DBackground />

		<!-- Contenido sobre el 3D -->
		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
