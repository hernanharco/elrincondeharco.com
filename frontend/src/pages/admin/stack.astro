---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StackEditor from '../../components/admin/StackEditor.svelte';

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Stack" currentPath={currentPath}>
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-zinc-100 mb-8">Editar Stack</h1>
    <StackEditor client:load />
  </div>
</AdminLayout>
