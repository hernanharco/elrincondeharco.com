---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ProjectsEditor from '../../components/admin/ProjectsEditor.svelte';

const currentPath = Astro.url.pathname;
---

<AdminLayout title="Proyectos" currentPath={currentPath}>
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-zinc-100 mb-8">Editar Proyectos</h1>
    <ProjectsEditor client:load />
  </div>
</AdminLayout>
