---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import SectorProjects from '../components/sections/SectorProjects.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTA from '../components/sections/CTA.astro';
import RecruiterHero from '../components/sections/recruiter/RecruiterHero.astro';
import RecruiterStack from '../components/sections/recruiter/RecruiterStack.astro';
import RecruiterProjects from '../components/sections/recruiter/RecruiterProjects.astro';
import RecruiterInfra from '../components/sections/recruiter/RecruiterInfra.astro';
import RecruiterTimeline from '../components/sections/recruiter/RecruiterTimeline.astro';
import RecruiterCertifications from '../components/sections/recruiter/RecruiterCertifications.astro';
import RecruiterGitHub from '../components/sections/recruiter/RecruiterGitHub.astro';
import RecruiterMethod from '../components/sections/recruiter/RecruiterMethod.astro';
---

<Layout
  title="El Rincom de Harco — Soluciones Digitales para tu Negocio"
  description="Desarrollador web en Asturias. Creo sitios web profesionales, tiendas online y sistemas a medida para hostelería, inmobiliarias, clínicas y más. 14+ años de experiencia."
>
  <!-- ═══ MODO CLIENTE ═══ -->
  <div class="client-content">
    <main>
      <Navbar />
      <Hero />
      <Stats />
      <SectorProjects />
      <Testimonials />
      <CTA />
    </main>
  </div>

  <!-- ═══ MODO RECRUITER ═══ -->
  <div class="recruiter-content">
    <!-- Theme toggle -->
    <div style="position:fixed;top:1rem;right:1rem;z-index:9999;display:flex;gap:0.5rem;" id="recruiter-theme-toggle">
      <button id="theme-btn" style="width:40px;height:40px;border-radius:50%;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.05);color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;backdrop-filter:blur(8px);transition:all 0.2s;" title="Cambiar tema">🌙</button>
    </div>

    <RecruiterHero />
    <RecruiterStack />
    <RecruiterProjects />
    <RecruiterTimeline />
    <RecruiterMethod />
    <RecruiterGitHub />
    <RecruiterCertifications />
    <RecruiterInfra />
  </div>
</Layout>

<style is:global>
  /* ── Dual Mode: ocultar recruiter por defecto ────────────── */
  .recruiter-content {
    display: none !important;
  }
  .client-content {
    display: block;
  }
  body[data-mode="recruiter"] .client-content {
    display: none !important;
  }
  body[data-mode="recruiter"] .recruiter-content {
    display: block !important;
  }
</style>

<script>
  // ── Router modo dual ──────────────────────────────────────
  // Escucha eventos del RobotAssistant y DestructionEffect
  // para togglear entre modo cliente y recruiter

  (function () {
    // Al cargar, verificar si ya está en modo recruiter
    const savedMode = localStorage.getItem("portfolio-mode");
    if (savedMode === "recruiter") {
      document.body.setAttribute("data-mode", "recruiter");
    }

    // Cuando la destrucción termina, activar modo recruiter
    document.addEventListener("mode:transition-complete", () => {
      document.body.setAttribute("data-mode", "recruiter");
    });

    // Cuando vuelve a modo cliente
    document.addEventListener("mode:switch-to-client", () => {
      document.body.removeAttribute("data-mode");
    });

    // ── Theme toggle ──────────────────────────────────────────
    const themeBtn = document.getElementById("theme-btn");
    const savedTheme = localStorage.getItem("recruiter-theme");
    if (savedTheme === "light") {
      document.body.setAttribute("data-recruiter-theme", "light");
      if (themeBtn) themeBtn.textContent = "☀️";
    }
    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const current = document.body.getAttribute("data-recruiter-theme");
        if (current === "light") {
          document.body.removeAttribute("data-recruiter-theme");
          localStorage.setItem("recruiter-theme", "dark");
          themeBtn.textContent = "🌙";
        } else {
          document.body.setAttribute("data-recruiter-theme", "light");
          localStorage.setItem("recruiter-theme", "light");
          themeBtn.textContent = "☀️";
        }
      });
    }
  })();
</script>
