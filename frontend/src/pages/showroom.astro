---
import Layout from '../layouts/Layout.astro';
import ShowroomGrid from '../components/sections/ShowroomGrid.svelte';

const currentPath = Astro.url.pathname;
---

<Layout title="Showroom de Prototipos" currentPath={currentPath}>
  <!-- Botón Volver al Inicio -->
  <div class="sticky top-0 z-40 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800">
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-zinc-400 hover:text-amber-400 transition-colors duration-200"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span class="font-medium">Volver al Inicio</span>
      </a>
    </div>
  </div>

  <!-- Grid de Showroom -->
  <ShowroomGrid client:load />
</Layout>
