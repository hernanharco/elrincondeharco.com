---
// Robot3D.astro — Robot 3D que sigue el cursor
// Three.js con geometrías básicas: cubo cabeza, esferas ojos, antena
// Reemplaza el SVG del RobotAssistant
---

<div id="robot-3d-container" aria-hidden="true">
  <canvas id="robot-3d-canvas"></canvas>
</div>

<style>
  #robot-3d-container {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    width: 80px;
    height: 80px;
    z-index: 9999;
    pointer-events: none;
    cursor: pointer;
  }
  #robot-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 640px) {
    #robot-3d-container {
      width: 60px;
      height: 60px;
      bottom: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

<script>
  import * as THREE from "three";

  (function () {
    const container = document.getElementById("robot-3d-container");
    const canvas = document.getElementById("robot-3d-canvas");
    if (!container || !canvas) return;

    // ── Scene ────────────────────────────────────────────────
    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0, 5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setSize(80, 80);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // ── Lights ───────────────────────────────────────────────
    const ambient = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambient);

    const dirLight = new THREE.DirectionalLight(0x06b6d4, 0.8);
    dirLight.position.set(3, 5, 5);
    scene.add(dirLight);

    const backLight = new THREE.DirectionalLight(0x3b82f6, 0.3);
    backLight.position.set(-3, -3, -3);
    scene.add(backLight);

    // ── Robot Group ──────────────────────────────────────────
    const robot = new THREE.Group();

    // Cabeza (cubo principal)
    const headGeo = new THREE.BoxGeometry(1.8, 1.6, 1.6);
    const headMat = new THREE.MeshStandardMaterial({
      color: 0x1a1a2e,
      metalness: 0.3,
      roughness: 0.4,
      transparent: true,
      opacity: 0.95,
    });
    const head = new THREE.Mesh(headGeo, headMat);
    head.position.y = 0;
    robot.add(head);

    // Antena
    const antennaMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.3,
      metalness: 0.8,
      roughness: 0.2,
    });
    const antennaBase = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.12, 0.6, 8), antennaMat);
    antennaBase.position.set(0, 1.1, 0);
    robot.add(antennaBase);

    const antennaBall = new THREE.Mesh(new THREE.SphereGeometry(0.15, 12, 12), antennaMat);
    antennaBall.position.set(0, 1.45, 0);
    robot.add(antennaBall);

    // Ojos (glow)
    const eyeMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.5,
    });
    const eyeWhiteMat = new THREE.MeshStandardMaterial({
      color: 0x0a0a0f,
      metalness: 0.2,
      roughness: 0.8,
    });

    const leftEyeWhite = new THREE.Mesh(new THREE.SphereGeometry(0.3, 16, 16), eyeWhiteMat);
    leftEyeWhite.position.set(-0.45, 0.2, 0.95);
    robot.add(leftEyeWhite);

    const rightEyeWhite = new THREE.Mesh(new THREE.SphereGeometry(0.3, 16, 16), eyeWhiteMat);
    rightEyeWhite.position.set(0.45, 0.2, 0.95);
    robot.add(rightEyeWhite);

    const leftEye = new THREE.Mesh(new THREE.SphereGeometry(0.15, 16, 16), eyeMat);
    leftEye.position.set(-0.45, 0.2, 1.05);
    robot.add(leftEye);

    const rightEye = new THREE.Mesh(new THREE.SphereGeometry(0.15, 16, 16), eyeMat);
    rightEye.position.set(0.45, 0.2, 1.05);
    robot.add(rightEye);

    // Boca (linea de LEDs)
    const mouthMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.2,
    });
    for (let i = -2; i <= 2; i++) {
      const dot = new THREE.Mesh(new THREE.SphereGeometry(0.04, 8, 8), mouthMat);
      dot.position.set(i * 0.15, -0.35, 0.98);
      robot.add(dot);
    }

    // Orejas / laterales
    const earMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      metalness: 0.6,
      roughness: 0.3,
    });
    const leftEar = new THREE.Mesh(new THREE.BoxGeometry(0.2, 0.6, 0.3), earMat);
    leftEar.position.set(-1.05, 0.1, 0);
    robot.add(leftEar);

    const rightEar = new THREE.Mesh(new THREE.BoxGeometry(0.2, 0.6, 0.3), earMat);
    rightEar.position.set(1.05, 0.1, 0);
    robot.add(rightEar);

    scene.add(robot);

    // ── Mouse tracking ──────────────────────────────────────
    let mouseX = 0;
    let mouseY = 0;
    let targetRotX = 0;
    let targetRotY = 0;

    document.addEventListener("mousemove", (e) => {
      // Normalizar coordenadas del mouse relativo al viewport
      mouseX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(e.clientY / window.innerHeight) * 2 + 1;

      // Mapear a ángulos de rotación suaves
      targetRotY = mouseX * 0.4;  //左右 rotation (y axis)
      targetRotX = mouseY * 0.2;  //上下 rotation (x axis)
    });

    // Tambien seguir el mouse en mobile (touch)
    document.addEventListener("touchmove", (e) => {
      const touch = e.touches[0];
      if (!touch) return;
      mouseX = (touch.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(touch.clientY / window.innerHeight) * 2 + 1;
      targetRotY = mouseX * 0.4;
      targetRotX = mouseY * 0.2;
    });

    // ── Animation loop ───────────────────────────────────────
    function animate() {
      // Interpolación suave (lerp) hacia la posición del mouse
      robot.rotation.y += (targetRotY - robot.rotation.y) * 0.08;
      robot.rotation.x += (targetRotX - robot.rotation.x) * 0.08;

      // Floating suave
      const floatY = Math.sin(Date.now() * 0.002) * 0.08;
      robot.position.y = floatY;

      // Pupilas brillan más intenso
      const glowIntensity = 0.3 + Math.sin(Date.now() * 0.003) * 0.2;
      eyeMat.emissiveIntensity = glowIntensity;

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }

    animate();

    // ── Click on robot opens the modal ──────────────────────
    container.addEventListener("click", () => {
      const modal = document.getElementById("robot-modal");
      if (modal) {
        const openModal = () => {
          modal.setAttribute("aria-hidden", "false");
          modal.classList.add("open");
        };
        // Abrir modal con "to-recruiter"
        // Disparamos click en el botón oculto
        const robotBtn = document.getElementById("robot-btn");
        if (robotBtn) {
          robotBtn.click();
        } else {
          openModal();
        }
      }
    });

    // ── Cleanup on page unload ─────────────────────────────
    window.addEventListener("beforeunload", () => {
      renderer.dispose();
    });
  })();
</script>
