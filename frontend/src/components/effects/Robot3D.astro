---
// Robot3D.astro — Robot 3D que sigue el cursor
// Three.js con geometrías básicas: cubo cabeza, esferas ojos, antena
// Reemplaza el SVG del RobotAssistant
---

<div id="robot-3d-container" aria-hidden="true">
  <canvas id="robot-3d-canvas"></canvas>
</div>

<style>
  #robot-3d-container {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    width: 80px;
    height: 80px;
    z-index: 9999;
    pointer-events: none;
    cursor: pointer;
  }
  #robot-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 640px) {
    #robot-3d-container {
      width: 60px;
      height: 60px;
      bottom: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

<script>
  import * as THREE from "three";

  (function () {
    const container = document.getElementById("robot-3d-container");
    const canvas = document.getElementById("robot-3d-canvas");
    if (!container || !canvas) return;

    // ── Scene ────────────────────────────────────────────────
    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0, 5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setSize(80, 80);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // ── Lights ───────────────────────────────────────────────
    const ambient = new THREE.AmbientLight(0xffffff, 0.6);
    scene.add(ambient);

    const dirLight = new THREE.DirectionalLight(0x06b6d4, 0.8);
    dirLight.position.set(3, 5, 5);
    scene.add(dirLight);

    const backLight = new THREE.DirectionalLight(0x3b82f6, 0.3);
    backLight.position.set(-3, -3, -3);
    scene.add(backLight);

    // ── Creature Group (mascota estilo logo) ────────────────
    const creature = new THREE.Group();

    // Cuerpo principal (blob suave, estirado)
    const bodyMat = new THREE.MeshStandardMaterial({
      color: 0x0a0a1a,
      roughness: 0.3,
      metalness: 0.1,
      transparent: true,
      opacity: 0.92,
    });
    const body = new THREE.Mesh(new THREE.SphereGeometry(1.1, 24, 24), bodyMat);
    body.scale.set(1.3, 1.1, 0.9);
    body.position.y = -0.1;
    creature.add(body);

    // Ribbon decorativo (como el logo) - toroide que rodea el cuerpo
    const ribbonMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.15,
      roughness: 0.2,
      metalness: 0.3,
      transparent: true,
      opacity: 0.7,
    });
    const ribbon = new THREE.Mesh(new THREE.TorusGeometry(1.0, 0.08, 12, 32), ribbonMat);
    ribbon.rotation.x = Math.PI / 2.5;
    ribbon.rotation.z = 0.3;
    ribbon.position.y = 0.1;
    creature.add(ribbon);

    const ribbon2 = new THREE.Mesh(new THREE.TorusGeometry(0.85, 0.06, 10, 28), ribbonMat);
    ribbon2.material = ribbonMat.clone();
    ribbon2.material.color.setHex(0xfbbf24);
    ribbon2.material.emissive.setHex(0xfbbf24);
    ribbon2.rotation.x = Math.PI / 1.8;
    ribbon2.rotation.z = -0.4;
    ribbon2.position.y = -0.1;
    creature.add(ribbon2);

    // Ojos grandes (kawaii)
    const eyeWhiteMat = new THREE.MeshStandardMaterial({
      color: 0xffffff,
      roughness: 0.1,
      metalness: 0.0,
    });
    const pupilMat = new THREE.MeshStandardMaterial({
      color: 0x0a0a1a,
      roughness: 0.0,
    });
    const irisMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.6,
      roughness: 0.1,
    });

    // Ojo izquierdo
    const lEye = new THREE.Mesh(new THREE.SphereGeometry(0.4, 20, 20), eyeWhiteMat);
    lEye.position.set(-0.55, 0.35, 0.95);
    lEye.scale.set(0.9, 1, 0.5);
    creature.add(lEye);

    const lIris = new THREE.Mesh(new THREE.SphereGeometry(0.25, 16, 16), irisMat);
    lIris.position.set(-0.55, 0.35, 1.05);
    lIris.scale.set(0.8, 0.8, 0.3);
    creature.add(lIris);

    const lPupil = new THREE.Mesh(new THREE.SphereGeometry(0.1, 12, 12), pupilMat);
    lPupil.position.set(-0.55, 0.35, 1.1);
    creature.add(lPupil);

    // Ojo derecho
    const rEye = new THREE.Mesh(new THREE.SphereGeometry(0.4, 20, 20), eyeWhiteMat);
    rEye.position.set(0.55, 0.35, 0.95);
    rEye.scale.set(0.9, 1, 0.5);
    creature.add(rEye);

    const rIris = new THREE.Mesh(new THREE.SphereGeometry(0.25, 16, 16), irisMat);
    rIris.position.set(0.55, 0.35, 1.05);
    rIris.scale.set(0.8, 0.8, 0.3);
    creature.add(rIris);

    const rPupil = new THREE.Mesh(new THREE.SphereGeometry(0.1, 12, 12), pupilMat);
    rPupil.position.set(0.55, 0.35, 1.1);
    creature.add(rPupil);

    // Mejillas sonrosadas
    const blushMat = new THREE.MeshStandardMaterial({
      color: 0xfbbf24,
      transparent: true,
      opacity: 0.2,
      emissive: 0xfbbf24,
      emissiveIntensity: 0.1,
    });
    const blushL = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 12), blushMat);
    blushL.position.set(-0.75, -0.1, 0.8);
    blushL.scale.set(1, 0.6, 0.4);
    creature.add(blushL);

    const blushR = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 12), blushMat);
    blushR.position.set(0.75, -0.1, 0.8);
    blushR.scale.set(1, 0.6, 0.4);
    creature.add(blushR);

    // Boquita sonrisa (toro pequeño)
    const mouthMat = new THREE.MeshStandardMaterial({
      color: 0xfbbf24,
      emissive: 0xfbbf24,
      emissiveIntensity: 0.2,
    });
    const mouth = new THREE.Mesh(new THREE.TorusGeometry(0.15, 0.04, 6, 12), mouthMat);
    mouth.position.set(0, -0.25, 1.0);
    mouth.rotation.x = Math.PI / 3;
    mouth.rotation.z = Math.PI;
    creature.add(mouth);

    // Estrella flotante (accesorio)
    const starMat = new THREE.MeshStandardMaterial({
      color: 0xfbbf24,
      emissive: 0xfbbf24,
      emissiveIntensity: 0.4,
      transparent: true,
      opacity: 0.6,
    });
    const star = new THREE.Mesh(new THREE.OctahedronGeometry(0.15, 0), starMat);
    star.position.set(0.7, 0.9, 0.4);
    creature.add(star);

    const star2 = star.clone();
    star2.material = starMat.clone();
    star2.material.color.setHex(0x06b6d4);
    star2.material.emissive.setHex(0x06b6d4);
    star2.position.set(-0.8, 0.7, 0.5);
    star2.scale.set(0.6, 0.6, 0.6);
    creature.add(star2);

    scene.add(creature);

    // ── Mouse tracking ──────────────────────────────────────
    let mouseX = 0;
    let mouseY = 0;
    let targetRotX = 0;
    let targetRotY = 0;

    document.addEventListener("mousemove", (e) => {
      // Normalizar coordenadas del mouse relativo al viewport
      mouseX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(e.clientY / window.innerHeight) * 2 + 1;

      // Mapear a ángulos de rotación suaves
      targetRotY = mouseX * 0.4;  //左右 rotation (y axis)
      targetRotX = mouseY * 0.2;  //上下 rotation (x axis)
    });

    // Tambien seguir el mouse en mobile (touch)
    document.addEventListener("touchmove", (e) => {
      const touch = e.touches[0];
      if (!touch) return;
      mouseX = (touch.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(touch.clientY / window.innerHeight) * 2 + 1;
      targetRotY = mouseX * 0.4;
      targetRotX = mouseY * 0.2;
    });

    // ── Animation loop ───────────────────────────────────────
    function animate() {
      // Interpolación suave (lerp) hacia la posición del mouse
      creature.rotation.y += (targetRotY - creature.rotation.y) * 0.08;
      creature.rotation.x += (targetRotX - creature.rotation.x) * 0.08;

      // Floating suave
      const floatY = Math.sin(Date.now() * 0.002) * 0.1;
      creature.position.y = floatY;

      // Estrellas rotan
      star.rotation.x += 0.02;
      star.rotation.y += 0.03;
      star2.rotation.x -= 0.03;
      star2.rotation.z += 0.02;

      // Ribbon pulsa
      ribbon.scale.setScalar(1 + Math.sin(Date.now() * 0.001) * 0.02);
      ribbon2.scale.setScalar(1 + Math.sin(Date.now() * 0.001 + 1) * 0.02);

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }

    animate();

    // ── Click on robot opens the modal ──────────────────────
    container.addEventListener("click", () => {
      const modal = document.getElementById("robot-modal");
      if (modal) {
        const openModal = () => {
          modal.setAttribute("aria-hidden", "false");
          modal.classList.add("open");
        };
        // Abrir modal con "to-recruiter"
        // Disparamos click en el botón oculto
        const robotBtn = document.getElementById("robot-btn");
        if (robotBtn) {
          robotBtn.click();
        } else {
          openModal();
        }
      }
    });

    // ── Cleanup on page unload ─────────────────────────────
    window.addEventListener("beforeunload", () => {
      renderer.dispose();
    });
  })();
</script>
