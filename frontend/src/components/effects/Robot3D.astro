---
// Robot3D.astro — Orbit: esfera blanca + aros orbitales azules
// Ojos amarillos tipo cámara que parpadean, sigue el mouse, click abre modal
---

<div id="robot-3d-container" aria-hidden="true">
  <canvas id="robot-3d-canvas"></canvas>
</div>

<style>
  #robot-3d-container {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    width: 90px;
    height: 90px;
    z-index: 9999;
    cursor: pointer;
    border-radius: 50%;
    transition: transform 0.2s ease;
  }
  #robot-3d-container:hover {
    transform: scale(1.08);
  }
  #robot-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 50%;
  }
  @media (max-width: 640px) {
    #robot-3d-container {
      width: 65px;
      height: 65px;
      bottom: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

<script>
  import * as THREE from "three";

  (function () {
    const container = document.getElementById("robot-3d-container");
    const canvas = document.getElementById("robot-3d-canvas");
    if (!container || !canvas) return;

    const W = 90;
    const H = 90;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
    camera.position.set(0, 0.3, 5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(W, H);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // ── Lights ───────────────────────────────────────────────
    scene.add(new THREE.AmbientLight(0xffffff, 0.7));
    const dl = new THREE.DirectionalLight(0xffffff, 1.2);
    dl.position.set(4, 6, 6);
    scene.add(dl);
    const bl = new THREE.DirectionalLight(0x06b6d4, 0.3);
    bl.position.set(-4, -3, -5);
    scene.add(bl);

    // ── Orbit Group ──────────────────────────────────────────
    const orbit = new THREE.Group();

    // Esfera principal (blanco suave)
    const sphereMat = new THREE.MeshStandardMaterial({
      color: 0xf0f4f8,
      roughness: 0.15,
      metalness: 0.05,
    });
    const sphere = new THREE.Mesh(new THREE.SphereGeometry(1.2, 32, 32), sphereMat);
    orbit.add(sphere);

    // Aro orbital principal (azul cyan)
    const ringMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.15,
      transparent: true,
      opacity: 0.5,
      roughness: 0.2,
      metalness: 0.4,
      side: THREE.DoubleSide,
    });
    const ring = new THREE.Mesh(new THREE.TorusGeometry(1.6, 0.05, 16, 48), ringMat);
    ring.rotation.x = Math.PI / 2.8;
    ring.rotation.z = 0.4;
    orbit.add(ring);

    // Aro secundario (azul más claro)
    const ring2Mat = ringMat.clone();
    ring2Mat.color.setHex(0x38bdf8);
    ring2Mat.emissive.setHex(0x38bdf8);
    ring2Mat.opacity = 0.3;
    const ring2 = new THREE.Mesh(new THREE.TorusGeometry(1.45, 0.03, 12, 40), ring2Mat);
    ring2.rotation.x = Math.PI / 1.6;
    ring2.rotation.z = -0.6;
    orbit.add(ring2);

    // Ojo izquierdo (amarillo cámara)
    const eyeMat = new THREE.MeshStandardMaterial({
      color: 0xfbbf24,
      emissive: 0xfbbf24,
      emissiveIntensity: 0.5,
      roughness: 0.2,
      metalness: 0.1,
    });
    const eyeWhiteMat = new THREE.MeshStandardMaterial({
      color: 0x1a1a2e,
      roughness: 0.3,
    });

    // Anillo exterior ojo izquierdo
    const lRing = new THREE.Mesh(new THREE.TorusGeometry(0.28, 0.06, 12, 20), eyeWhiteMat);
    lRing.position.set(-0.45, 0.2, 1.05);
    orbit.add(lRing);

    // Lente amarillo izquierdo
    const lLens = new THREE.Mesh(new THREE.CircleGeometry(0.22, 20), eyeMat);
    lLens.position.set(-0.45, 0.2, 1.08);
    orbit.add(lLens);

    // Pupila izquierda
    const pupilMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0f });
    const lPupil = new THREE.Mesh(new THREE.CircleGeometry(0.08, 16), pupilMat);
    lPupil.position.set(-0.45, 0.2, 1.12);
    orbit.add(lPupil);

    // Anillo exterior ojo derecho
    const rRing = new THREE.Mesh(new THREE.TorusGeometry(0.28, 0.06, 12, 20), eyeWhiteMat);
    rRing.position.set(0.45, 0.2, 1.05);
    orbit.add(rRing);

    // Lente amarillo derecho
    const rLens = new THREE.Mesh(new THREE.CircleGeometry(0.22, 20), eyeMat);
    rLens.position.set(0.45, 0.2, 1.08);
    orbit.add(rLens);

    // Pupila derecha
    const rPupil = new THREE.Mesh(new THREE.CircleGeometry(0.08, 16), pupilMat);
    rPupil.position.set(0.45, 0.2, 1.12);
    orbit.add(rPupil);

    // LED indicador base (punto azul)
    const ledMat = new THREE.MeshStandardMaterial({
      color: 0x06b6d4,
      emissive: 0x06b6d4,
      emissiveIntensity: 0.6,
    });
    const led = new THREE.Mesh(new THREE.SphereGeometry(0.08, 12, 12), ledMat);
    led.position.set(0, -1.2, 1.2);
    orbit.add(led);

    scene.add(orbit);

    // ── Parpadeo ────────────────────────────────────────────
    let isBlinking = false;
    let blinkTimer = 3000 + Math.random() * 2000;

    function blink() {
      if (isBlinking) return;
      isBlinking = true;
      lLens.scale.y = 0.01;
      rLens.scale.y = 0.01;
      lPupil.scale.y = 0.01;
      rPupil.scale.y = 0.01;
      setTimeout(() => {
        lLens.scale.y = 1;
        rLens.scale.y = 1;
        lPupil.scale.y = 1;
        rPupil.scale.y = 1;
        isBlinking = false;
        blinkTimer = 2500 + Math.random() * 3000;
      }, 120);
    }

    // ── Mouse tracking ──────────────────────────────────────
    let targetRotY = 0;
    let targetRotX = 0;

    document.addEventListener("mousemove", (e) => {
      const mx = (e.clientX / window.innerWidth) * 2 - 1;
      const my = -(e.clientY / window.innerHeight) * 2 + 1;
      targetRotY = mx * 0.35;
      targetRotX = my * 0.18;
    });
    document.addEventListener("touchmove", (e) => {
      const t = e.touches[0];
      if (!t) return;
      targetRotY = ((t.clientX / window.innerWidth) * 2 - 1) * 0.35;
      targetRotX = (-(t.clientY / window.innerHeight) * 2 + 1) * 0.18;
    });

    // ── Animation ────────────────────────────────────────────
    let blinkAcc = 0;

    function animate() {
      const dt = 0.016;
      blinkAcc += dt * 1000;

      // Parpadeo automático
      if (blinkAcc > blinkTimer && !isBlinking) {
        blinkAcc = 0;
        blink();
      }

      // Rotación suave hacia el mouse
      orbit.rotation.y += (targetRotY - orbit.rotation.y) * 0.08;
      orbit.rotation.x += (targetRotX - orbit.rotation.x) * 0.08;

      // Flotación
      orbit.position.y = Math.sin(Date.now() * 0.0015) * 0.08;

      // Aros rotan
      ring.rotation.x += 0.003;
      ring.rotation.z += 0.002;
      ring2.rotation.x -= 0.004;
      ring2.rotation.z += 0.003;

      // LED pulsa
      ledMat.emissiveIntensity = 0.4 + Math.sin(Date.now() * 0.004) * 0.2;

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }
    animate();

    // ── Click → modal ──────────────────────────────────────
    container.addEventListener("click", () => {
      const robotBtn = document.getElementById("robot-btn");
      if (robotBtn) robotBtn.click();
    });

    // ── Resize ───────────────────────────────────────────────
    function onResize() {
      const size = Math.min(window.innerWidth * 0.12, 90);
      const dpr = Math.min(window.devicePixelRatio, 2);
      container.style.width = size + "px";
      container.style.height = size + "px";
      renderer.setSize(size, size);
      renderer.setPixelRatio(dpr);
    }
    window.addEventListener("resize", onResize);

    window.addEventListener("beforeunload", () => renderer.dispose());
  })();
</script>
