---
// Robot3D.astro — Mascota 3D interactiva
// Estilos: orbit (esfera + aros) | chibi (cabezón + bufanda)
// Double-click cambia de estilo. Click abre modal. Sigue el mouse.
---

<div id="robot-3d-container" aria-hidden="true">
  <canvas id="robot-3d-canvas"></canvas>
</div>

<style>
  #robot-3d-container {
    position: fixed;
    bottom: 1rem;
    right: 1rem;
    width: 90px;
    height: 90px;
    z-index: 9999;
    cursor: pointer;
    border-radius: 50%;
    transition: transform 0.2s ease;
  }
  #robot-3d-container:hover {
    transform: scale(1.08);
  }
  #robot-3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 50%;
  }
  @media (max-width: 640px) {
    #robot-3d-container {
      width: 65px;
      height: 65px;
      bottom: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

<script>
  import * as THREE from "three";

  (function () {
    const container = document.getElementById("robot-3d-container");
    const canvas = document.getElementById("robot-3d-canvas");
    if (!container || !canvas) return;

    const STYLE_KEY = "robot-style";
    let currentStyle = localStorage.getItem(STYLE_KEY) || "orbit";
    let currentGroup = null;
    let animData = {};

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
    camera.position.set(0, 0.3, 5);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    const size = Math.min(window.innerWidth * 0.12, 90);
    renderer.setSize(size, size);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // ── Lights ───────────────────────────────────────────────
    scene.add(new THREE.AmbientLight(0xffffff, 0.7));
    const dl = new THREE.DirectionalLight(0xffffff, 1.2);
    dl.position.set(4, 6, 6); scene.add(dl);
    const bl = new THREE.DirectionalLight(0x06b6d4, 0.3);
    bl.position.set(-4, -3, -5); scene.add(bl);

    // ── Build: Orbit ─────────────────────────────────────────
    function buildOrbit() {
      const g = new THREE.Group();
      const sMat = new THREE.MeshStandardMaterial({ color: 0xf0f4f8, roughness: 0.15, metalness: 0.05 });
      g.add(new THREE.Mesh(new THREE.SphereGeometry(1.2, 32, 32), sMat));

      const rMat = new THREE.MeshStandardMaterial({ color: 0x06b6d4, emissive: 0x06b6d4, emissiveIntensity: 0.15, transparent: true, opacity: 0.5, roughness: 0.2, metalness: 0.4, side: THREE.DoubleSide });
      const r1 = new THREE.Mesh(new THREE.TorusGeometry(1.6, 0.05, 16, 48), rMat);
      r1.rotation.x = Math.PI / 2.8; r1.rotation.z = 0.4; g.add(r1);

      const r2Mat = rMat.clone(); r2Mat.color.setHex(0x38bdf8); r2Mat.emissive.setHex(0x38bdf8); r2Mat.opacity = 0.3;
      const r2 = new THREE.Mesh(new THREE.TorusGeometry(1.45, 0.03, 12, 40), r2Mat);
      r2.rotation.x = Math.PI / 1.6; r2.rotation.z = -0.6; g.add(r2);

      // Ojos
      const eMat = new THREE.MeshStandardMaterial({ color: 0xfbbf24, emissive: 0xfbbf24, emissiveIntensity: 0.5, roughness: 0.2 });
      const eMat2 = new THREE.MeshStandardMaterial({ color: 0x1a1a2e, roughness: 0.3 });
      const pMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0f });

      function addEye(x) {
        const rim = new THREE.Mesh(new THREE.TorusGeometry(0.28, 0.06, 12, 20), eMat2);
        rim.position.set(x, 0.2, 1.05); g.add(rim);
        const lens = new THREE.Mesh(new THREE.CircleGeometry(0.22, 20), eMat);
        lens.position.set(x, 0.2, 1.08); g.add(lens);
        const pup = new THREE.Mesh(new THREE.CircleGeometry(0.08, 16), pMat);
        pup.position.set(x, 0.2, 1.12); g.add(pup);
        return { lens, pup };
      }
      const eyes = [addEye(-0.45), addEye(0.45)];
      const lLens = eyes[0].lens, rLens = eyes[1].lens;
      const lPup = eyes[0].pup, rPup = eyes[1].pup;

      const ledMat = new THREE.MeshStandardMaterial({ color: 0x06b6d4, emissive: 0x06b6d4, emissiveIntensity: 0.6 });
      const led = new THREE.Mesh(new THREE.SphereGeometry(0.08, 12, 12), ledMat);
      led.position.set(0, -1.2, 1.2); g.add(led);

      animData = { lLens, rLens, lPup, rPup, ring: r1, ring2: r2, ledMat, blinkTargets: [lLens, rLens, lPup, rPup] };
      return g;
    }

    // ── Build: Chibi ─────────────────────────────────────────
    function buildChibi() {
      const g = new THREE.Group();
      const gHead = new THREE.Group();

      // Cabeza grande (mas grande que orbit)
      const headMat = new THREE.MeshStandardMaterial({ color: 0xf0f4f8, roughness: 0.2, metalness: 0.05 });
      const head = new THREE.Mesh(new THREE.SphereGeometry(1.3, 28, 28), headMat);
      head.scale.set(1.1, 1.0, 0.9); gHead.add(head);

      // Cuerpo chico
      const bodyMat = new THREE.MeshStandardMaterial({ color: 0xf0f4f8, roughness: 0.3 });
      const body = new THREE.Mesh(new THREE.SphereGeometry(0.7, 20, 20), bodyMat);
      body.position.y = -1.3; body.scale.set(1.1, 0.8, 0.7); g.add(body);

      // Bufanda azul gordita
      const bufMat = new THREE.MeshStandardMaterial({ color: 0x06b6d4, emissive: 0x06b6d4, emissiveIntensity: 0.15, roughness: 0.4 });
      const buf = new THREE.Mesh(new THREE.TorusGeometry(0.9, 0.14, 10, 22), bufMat);
      buf.position.y = -0.4; buf.rotation.x = Math.PI / 2.2; buf.scale.set(1, 1, 0.5); g.add(buf);
      const buf2 = new THREE.Mesh(new THREE.TorusGeometry(0.95, 0.1, 8, 20), bufMat);
      buf2.position.y = -0.55; buf2.rotation.x = Math.PI / 1.8; buf2.scale.set(1, 1, 0.4); g.add(buf2);

      // Ojos grandes (blanco + amarillo + pupila independientes)
      const eyeWMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.1 });
      const irisMat = new THREE.MeshStandardMaterial({ color: 0xfbbf24, emissive: 0xfbbf24, emissiveIntensity: 0.6, roughness: 0.1 });
      const pMat = new THREE.MeshStandardMaterial({ color: 0x0a0a0f });

      function addEye(px, py) {
        const white = new THREE.Mesh(new THREE.SphereGeometry(0.32, 20, 20), eyeWMat);
        white.position.set(px, py, 0.95); white.scale.set(1.3, 1, 0.3); gHead.add(white);
        const iris = new THREE.Mesh(new THREE.SphereGeometry(0.2, 16, 16), irisMat);
        iris.position.set(px, py, 1.0); iris.scale.set(1.1, 0.9, 0.15); gHead.add(iris);
        const pup = new THREE.Mesh(new THREE.SphereGeometry(0.08, 12, 12), pMat);
        pup.position.set(px, py, 1.05); gHead.add(pup);
        return { white, iris, pup };
      }
      const el = addEye(-0.5, 0.35);
      const er = addEye(0.5, 0.35);

      // Guardar pupilas para tracking independiente
      const pupils = [el.pup, er.pup];
      const irises = [el.iris, er.iris];

      // Mejillas sonrosadas mas notorias
      const bMat = new THREE.MeshStandardMaterial({ color: 0xfbbf24, transparent: true, opacity: 0.2, emissive: 0xfbbf24, emissiveIntensity: 0.08 });
      const bl = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 12), bMat);
      bl.position.set(-0.8, -0.05, 0.75); bl.scale.set(1, 0.5, 0.3); gHead.add(bl);
      const br = bl.clone(); br.position.set(0.8, -0.05, 0.75); gHead.add(br);

      // Boquita sonrisa
      const mMat = new THREE.MeshStandardMaterial({ color: 0x06b6d4 });
      const mouth = new THREE.Mesh(new THREE.TorusGeometry(0.12, 0.03, 6, 10), mMat);
      mouth.position.set(0, -0.2, 0.95); mouth.rotation.x = Math.PI / 3; mouth.rotation.z = Math.PI; gHead.add(mouth);

      // Estrella decorativa
      const stMat = new THREE.MeshStandardMaterial({ color: 0xfbbf24, emissive: 0xfbbf24, emissiveIntensity: 0.3, transparent: true, opacity: 0.5 });
      const star = new THREE.Mesh(new THREE.OctahedronGeometry(0.14, 0), stMat);
      star.position.set(0.8, 0.9, 0.4); gHead.add(star);

      gHead.position.y = 0.05;
      g.add(gHead);

      animData = { lLens: el.white, rLens: er.white, lPup: el.pup, rPup: er.pup, pupils, irises, star, blinkTargets: [el.white, er.white, el.pup, er.pup] };
      return g;
    }

    // ── Switch style ─────────────────────────────────────────
    function switchStyle(style) {
      if (currentGroup) {
        scene.remove(currentGroup);
        // Dispose geometry and materials
        currentGroup.traverse((child) => {
          if (child.isMesh) {
            child.geometry?.dispose();
            if (Array.isArray(child.material)) child.material.forEach(m => m.dispose());
            else child.material?.dispose();
          }
        });
      }
      currentStyle = style;
      localStorage.setItem(STYLE_KEY, style);
      currentGroup = style === "chibi" ? buildChibi() : buildOrbit();
      scene.add(currentGroup);
    }

    // ── Init ─────────────────────────────────────────────────
    switchStyle(currentStyle);

    // ── Blink ────────────────────────────────────────────────
    let isBlinking = false;
    let blinkTimer = 3000 + Math.random() * 2000;
    let blinkAcc = 0;

    function blink() {
      if (isBlinking || !animData.blinkTargets) return;
      isBlinking = true;
      animData.blinkTargets.forEach(t => { t.scale.y = 0.01; });
      setTimeout(() => {
        animData.blinkTargets.forEach(t => { t.scale.y = 1; });
        isBlinking = false;
        blinkTimer = 2500 + Math.random() * 3000;
        blinkAcc = 0;
      }, 120);
    }

    // ── Mouse tracking ──────────────────────────────────────
    let targetRotY = 0, targetRotX = 0;
    document.addEventListener("mousemove", (e) => {
      targetRotY = ((e.clientX / window.innerWidth) * 2 - 1) * 0.35;
      targetRotX = (-(e.clientY / window.innerHeight) * 2 + 1) * 0.18;
    });
    document.addEventListener("touchmove", (e) => {
      const t = e.touches[0]; if (!t) return;
      targetRotY = ((t.clientX / window.innerWidth) * 2 - 1) * 0.35;
      targetRotX = (-(t.clientY / window.innerHeight) * 2 + 1) * 0.18;
    });

    // ── Right-click → switch style ─────────────────────────
    container.addEventListener("contextmenu", (e) => {
      e.preventDefault();
      const next = currentStyle === "orbit" ? "chibi" : "orbit";
      switchStyle(next);
    });

    // ── Left-click → open modal ─────────────────────────────
    container.addEventListener("click", () => {
      const robotBtn = document.getElementById("robot-btn");
      if (robotBtn) robotBtn.click();
    });

    // ── Animation ────────────────────────────────────────────
    function animate() {
      blinkAcc += 16;
      if (blinkAcc > blinkTimer && !isBlinking) { blinkAcc = 0; blink(); }

      if (currentGroup) {
        currentGroup.rotation.y += (targetRotY - currentGroup.rotation.y) * 0.08;
        currentGroup.rotation.x += (targetRotX - currentGroup.rotation.x) * 0.08;
        currentGroup.position.y = Math.sin(Date.now() * 0.0015) * 0.08;

        // Pupilas siguen el mouse (independiente de la rotacion del grupo)
        if (animData.pupils) {
          const px = targetRotY * 0.08;
          const py = targetRotX * 0.08;
          animData.pupils.forEach(p => { p.position.x += (px - (p.position.x - (p.userData?.baseX || p.position.x))) * 0.1; if (!p.userData) p.userData = {}; p.userData.baseX = p.position.x; });
          // Simplified: just move pupils left/right based on mouse
          animData.pupils[0].position.x = -0.5 + targetRotY * 0.12;
          animData.pupils[1].position.x = 0.5 + targetRotY * 0.12;
          animData.pupils[0].position.y = 0.35 + targetRotX * 0.08;
          animData.pupils[1].position.y = 0.35 + targetRotX * 0.08;
          // Also move irises slightly
          if (animData.irises) {
            animData.irises[0].position.x = -0.5 + targetRotY * 0.06;
            animData.irises[1].position.x = 0.5 + targetRotY * 0.06;
            animData.irises[0].position.y = 0.35 + targetRotX * 0.04;
            animData.irises[1].position.y = 0.35 + targetRotX * 0.04;
          }
        }
      }

      // Orbit-specific animations
      if (animData.ring) { animData.ring.rotation.x += 0.003; animData.ring.rotation.z += 0.002; }
      if (animData.ring2) { animData.ring2.rotation.x -= 0.004; animData.ring2.rotation.z += 0.003; }
      if (animData.ledMat) animData.ledMat.emissiveIntensity = 0.4 + Math.sin(Date.now() * 0.004) * 0.2;
      if (animData.star) { animData.star.rotation.x += 0.03; animData.star.rotation.y += 0.02; }

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    }
    animate();

    // ── Resize ───────────────────────────────────────────────
    function onResize() {
      const s = Math.min(window.innerWidth * 0.12, 90);
      container.style.width = s + "px"; container.style.height = s + "px";
      renderer.setSize(s, s);
    }
    window.addEventListener("resize", onResize);
    window.addEventListener("beforeunload", () => renderer.dispose());
  })();
</script>
