---
// CaosOrden.astro — Escena 3D: Caos → Orden
// Formas geométricas flotando en desorden que se organizan
// en una estructura armónica al hacer scroll o al cargar.
// Colores: rojo/anaranjado (caos) → amber/cyan (orden)
---

<div id="caos-orden-container" aria-hidden="true">
  <canvas id="caos-orden-canvas"></canvas>
</div>

<style>
  #caos-orden-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  #caos-orden-container.visible {
    opacity: 1;
  }
</style>

<script>
  import * as THREE from "three";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  (function () {
    const container = document.getElementById("caos-orden-container");
    const canvas = document.getElementById("caos-orden-canvas");
    if (!container || !canvas) return;

    // ── Solo en la home ────────────────────────────────────
    if (window.location.pathname !== "/" && !window.location.pathname.startsWith("/?")) {
      return;
    }

    // ── Móvil check ────────────────────────────────────────
    const isMobile = /Mobi|Android/i.test(navigator.userAgent);
    if (isMobile) {
      return;
    }

    // ── Si está en modo recruiter, no activar ──────────────
    if (localStorage.getItem("portfolio-mode") === "recruiter") {
      return;
    }

    // ── Scene Setup ─────────────────────────────────────────
    const scene = new THREE.Scene();

    const camera = new THREE.PerspectiveCamera(
      50,
      window.innerWidth / window.innerHeight,
      0.1,
      100
    );
    camera.position.set(0, 2, 12);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: window.devicePixelRatio < 2,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // ── Lights ──────────────────────────────────────────────
    const ambient = new THREE.AmbientLight(0xffffff, 0.4);
    scene.add(ambient);

    const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
    dirLight.position.set(5, 10, 7);
    scene.add(dirLight);

    const backLight = new THREE.DirectionalLight(0x06b6d4, 0.3);
    backLight.position.set(-5, -5, -5);
    scene.add(backLight);

    // ── Geometries ──────────────────────────────────────────
    const geometries = [
      new THREE.BoxGeometry(0.8, 0.8, 0.8),
      new THREE.IcosahedronGeometry(0.6, 0),
      new THREE.OctahedronGeometry(0.7, 0),
      new THREE.TorusGeometry(0.5, 0.2, 8, 16),
      new THREE.TetrahedronGeometry(0.7, 0),
      new THREE.DodecahedronGeometry(0.6, 0),
    ];

    const CHAOS_COLORS = [
      new THREE.Color("#ef4444"), // red
      new THREE.Color("#f97316"), // orange
      new THREE.Color("#dc2626"), // dark red
      new THREE.Color("#ea580c"), // deep orange
    ];

    const ORDER_COLORS = [
      new THREE.Color("#fbbf24"), // amber
      new THREE.Color("#06b6d4"), // cyan
      new THREE.Color("#f59e0b"), // gold
      new THREE.Color("#0ea5e9"), // sky blue
      new THREE.Color("#fbbf24"),
      new THREE.Color("#06b6d4"),
    ];

    // ── Create Objects ──────────────────────────────────────
    const NUM_OBJECTS = isMobile ? 10 : 28;
    const objects = [];

    // Target positions in a Fibonacci/Spiral arrangement
    const spiralPositions = [];
    const numTarget = NUM_OBJECTS;
    const radius = 4.5;
    for (let i = 0; i < numTarget; i++) {
      const t = i / (numTarget - 1);
      const angle = t * Math.PI * 6;
      const r = radius * (0.3 + t * 0.7);
      const x = Math.cos(angle) * r;
      const z = Math.sin(angle) * r;
      const y = (t - 0.5) * 3.5;
      spiralPositions.push({ x, y, z });
    }

    for (let i = 0; i < NUM_OBJECTS; i++) {
      const geo = geometries[i % geometries.length];
      const mat = new THREE.MeshStandardMaterial({
        color: CHAOS_COLORS[i % CHAOS_COLORS.length],
        metalness: 0.3,
        roughness: 0.6,
        transparent: true,
        opacity: 0.85,
      });
      const mesh = new THREE.Mesh(geo, mat);

      // Caos initial positions
      const angle = Math.random() * Math.PI * 2;
      const r = 2 + Math.random() * 3;
      mesh.position.set(
        Math.cos(angle) * r + (Math.random() - 0.5) * 2,
        (Math.random() - 0.5) * 5,
        Math.sin(angle) * r + (Math.random() - 0.5) * 2
      );

      // Random rotation
      mesh.rotation.set(
        Math.random() * Math.PI * 2,
        Math.random() * Math.PI * 2,
        Math.random() * Math.PI * 2
      );

      // Store chaos velocity for floating animation
      mesh.userData = {
        chaosVel: {
          x: (Math.random() - 0.5) * 0.02,
          y: (Math.random() - 0.5) * 0.02,
          z: (Math.random() - 0.5) * 0.02,
        },
        rotVel: {
          x: (Math.random() - 0.5) * 0.03,
          y: (Math.random() - 0.5) * 0.03,
          z: (Math.random() - 0.5) * 0.03,
        },
        targetPos: spiralPositions[i],
        targetColor: ORDER_COLORS[i % ORDER_COLORS.length].clone(),
        chaosColor: CHAOS_COLORS[i % CHAOS_COLORS.length].clone(),
        progress: 0,
        floatOffset: Math.random() * Math.PI * 2,
        floatSpeed: 0.3 + Math.random() * 0.4,
      };

      scene.add(mesh);
      objects.push(mesh);
    }

    // ── Connection Lines (only visible in ordered state) ────
    const lineMaterial = new THREE.LineBasicMaterial({
      color: 0x06b6d4,
      transparent: true,
      opacity: 0,
    });

    // Pre-compute connections (nearest neighbors)
    const connections = [];
    for (let i = 0; i < NUM_OBJECTS; i++) {
      for (let j = i + 1; j < NUM_OBJECTS; j++) {
        const di = spiralPositions[i];
        const dj = spiralPositions[j];
        const dist = Math.sqrt(
          (di.x - dj.x) ** 2 + (di.y - dj.y) ** 2 + (di.z - dj.z) ** 2
        );
        if (dist < 3) {
          connections.push({ i, j, dist });
        }
      }
    }

    // Limit to ~30 connections max
    connections.sort((a, b) => a.dist - b.dist);
    const activeConnections = connections.slice(0, 30);

    const lineMeshes = activeConnections.map((conn) => {
      const positions = new Float32Array(6);
      const geo = new THREE.BufferGeometry();
      geo.setAttribute("position", new THREE.BufferAttribute(positions, 3));
      const line = new THREE.Line(geo, lineMaterial.clone());
      line.visible = false;
      scene.add(line);
      return { line, conn };
    });

    // ── Particles ────────────────────────────────────────────
    const particleCount = 200;
    const particleGeo = new THREE.BufferGeometry();
    const particlePos = new Float32Array(particleCount * 3);
    const particleVel = [];
    for (let i = 0; i < particleCount; i++) {
      const r = 2 + Math.random() * 4;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.random() * Math.PI;
      particlePos[i * 3] = Math.sin(phi) * Math.cos(theta) * r;
      particlePos[i * 3 + 1] = (Math.random() - 0.5) * 4;
      particlePos[i * 3 + 2] = Math.sin(phi) * Math.sin(theta) * r;
      particleVel.push({
        x: (Math.random() - 0.5) * 0.005,
        y: (Math.random() - 0.5) * 0.005,
        z: (Math.random() - 0.5) * 0.005,
      });
    }
    particleGeo.setAttribute(
      "position",
      new THREE.BufferAttribute(particlePos, 3)
    );

    const particleMat = new THREE.PointsMaterial({
      color: 0xfbbf24,
      size: 0.04,
      transparent: true,
      opacity: 0.4,
      blending: THREE.AdditiveBlending,
    });
    const particleSystem = new THREE.Points(particleGeo, particleMat);
    scene.add(particleSystem);

    // ── State ────────────────────────────────────────────────
    let transitionProgress = 0; // 0 = chaos, 1 = order
    let hasTransitioned = false;
    let isTransitioning = false;
    let time = 0;

    // ── Transition Trigger ───────────────────────────────────
    // Auto-trigger after 2s OR on first scroll
    let triggerTimer = setTimeout(() => {
      startTransition();
    }, 2500);

    // Also trigger on first scroll
    const scrollTrigger = ScrollTrigger.create({
      trigger: document.body,
      start: "top top",
      onScrub: () => {
        if (!hasTransitioned && !isTransitioning) {
          startTransition();
        }
      },
    });

    function startTransition() {
      if (hasTransitioned || isTransitioning) return;
      isTransitioning = true;
      clearTimeout(triggerTimer);

      // Mostrar contenedor
      container.classList.add("visible");

      // Animar cada objeto
      objects.forEach((obj, idx) => {
        const ud = obj.userData;
        const delay = idx * 0.04;

        gsap.to(ud, {
          progress: 1,
          duration: 2.5,
          delay,
          ease: "power3.inOut",
          onComplete: () => {
            if (idx === objects.length - 1) {
              hasTransitioned = true;
              isTransitioning = false;
            }
          },
        });
      });

      // Mostrar líneas gradualmente
      lineMeshes.forEach(({ line, conn }, idx) => {
        const delay = 1 + idx * 0.05;
        gsap.to(line, {
          duration: 0.8,
          delay,
          onStart: () => {
            line.visible = true;
          },
        });
        gsap.to(line.material, {
          opacity: 0.3,
          duration: 1,
          delay,
          ease: "power2.out",
        });
      });

      // Partículas más brillantes
      gsap.to(particleMat, {
        opacity: 0.7,
        size: 0.06,
        duration: 2,
        delay: 0.5,
        ease: "power2.out",
      });
    }

    // ── Resize ──────────────────────────────────────────────
    function resize() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    }
    window.addEventListener("resize", resize);

    // ── Animation Loop ──────────────────────────────────────
    function animate() {
      requestAnimationFrame(animate);
      time += 0.01;

      // Update object positions based on progress
      objects.forEach((obj) => {
        const ud = obj.userData;
        const p = ud.progress; // 0 = chaos, 1 = order
        const ease = 1 - Math.pow(1 - p, 3); // cubic ease

        if (p < 1) {
          // Interpolate position
          const chaosX =
            obj.position.x + Math.sin(time + ud.floatOffset) * 0.02;
          const chaosY =
            obj.position.y + Math.cos(time * 0.7 + ud.floatOffset) * 0.02;
          const chaosZ =
            obj.position.z + Math.sin(time * 0.5 + ud.floatOffset) * 0.02;

          if (p === 0) {
            // Still in chaos - random drift
            obj.position.x += ud.chaosVel.x;
            obj.position.y += ud.chaosVel.y;
            obj.position.z += ud.chaosVel.z;
            obj.rotation.x += ud.rotVel.x;
            obj.rotation.y += ud.rotVel.y;
            obj.rotation.z += ud.rotVel.z;

            // Keep in bounds
            if (Math.abs(obj.position.x) > 5) ud.chaosVel.x *= -1;
            if (Math.abs(obj.position.y) > 3) ud.chaosVel.y *= -1;
            if (Math.abs(obj.position.z) > 5) ud.chaosVel.z *= -1;
          } else {
            // Transitioning
            const tPos = ud.targetPos;
            obj.position.x += (tPos.x - obj.position.x) * 0.04;
            obj.position.y += (tPos.y - obj.position.y) * 0.04;
            obj.position.z += (tPos.z - obj.position.z) * 0.04;

            obj.rotation.x += (0 - obj.rotation.x) * 0.02;
            obj.rotation.y += (time * 0.3 - obj.rotation.y) * 0.02;
            obj.rotation.z += (0 - obj.rotation.z) * 0.02;
          }

          // Color lerp
          const c = obj.material.color;
          c.lerp(ud.targetColor, 0.02);
        } else {
          // Ordered state — gentle floating
          const tPos = ud.targetPos;
          const floatY = Math.sin(time * ud.floatSpeed + ud.floatOffset) * 0.15;
          obj.position.x = tPos.x;
          obj.position.y = tPos.y + floatY;
          obj.position.z = tPos.z;

          obj.rotation.y += 0.005;
        }
      });

      // Update connection lines
      lineMeshes.forEach(({ line, conn }) => {
        if (!line.visible) return;
        const a = objects[conn.i];
        const b = objects[conn.j];
        if (!a || !b) return;
        const pos = line.geometry.attributes.position.array;
        pos[0] = a.position.x;
        pos[1] = a.position.y;
        pos[2] = a.position.z;
        pos[3] = b.position.x;
        pos[4] = b.position.y;
        pos[5] = b.position.z;
        line.geometry.attributes.position.needsUpdate = true;
      });

      // Particles
      const pPos = particleSystem.geometry.attributes.position.array;
      for (let i = 0; i < particleCount; i++) {
        pPos[i * 3] += particleVel[i].x;
        pPos[i * 3 + 1] += particleVel[i].y;
        pPos[i * 3 + 2] += particleVel[i].z;

        // Wrap around
        const r = Math.sqrt(
          pPos[i * 3] ** 2 +
            pPos[i * 3 + 1] ** 2 +
            pPos[i * 3 + 2] ** 2
        );
        if (r > 6) {
          pPos[i * 3] *= -0.5;
          pPos[i * 3 + 1] *= -0.5;
          pPos[i * 3 + 2] *= -0.5;
        }
      }
      particleSystem.geometry.attributes.position.needsUpdate = true;

      // Gentle camera drift
      if (hasTransitioned) {
        const driftX = Math.sin(time * 0.1) * 0.3;
        const driftY = Math.sin(time * 0.07) * 0.2;
        camera.position.x = driftX;
        camera.position.y = 2 + driftY;
        camera.lookAt(0, 0, 0);
      }

      renderer.render(scene, camera);
    }

    // Mostrar contenedor y arrancar animación
    // Inicialmente oculto, se muestra al iniciar
    requestAnimationFrame(() => {
      container.classList.add("visible");
    });

    animate();

    // Cleanup
    window.addEventListener("beforeunload", () => {
      ScrollTrigger.getById(scrollTrigger.id)?.kill();
      renderer.dispose();
      scene.traverse((child) => {
        if (child instanceof THREE.Mesh) {
          child.geometry?.dispose();
          child.material?.dispose();
        }
      });
    });
  })();
</script>
