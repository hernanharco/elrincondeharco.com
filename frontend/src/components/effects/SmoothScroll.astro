---
// SmoothScroll.astro
// Inicializa Lenis + GSAP ScrollTrigger + animaciones de entrada
// VERSIÓN CINEMÁTICA — con pinning, parallax y efectos direccionales
---

<script>
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ── Lenis Smooth Scroll ──────────────────────────────────
  const lenis = new Lenis({
    duration: 1.4,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    orientation: "vertical",
    smoothWheel: true,
    wheelMultiplier: 0.9,
    touchMultiplier: 1.2,
  });

  lenis.on("scroll", ScrollTrigger.update);
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  gsap.ticker.lagSmoothing(0);

  // ── Navegación suave ─────────────────────────────────────
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      const href = anchor.getAttribute("href");
      if (!href || href === "#") return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        lenis.scrollTo(target, { offset: -80, duration: 1.2 });
      }
    });
  });

  // ── Animaciones Cinemáticas ──────────────────────────────
  function setupAnimations() {
    // ▸ data-reveal-directions: left, right, scale, fade, up (default)
    const directionConfig = {
      left:   { x: -120, y: 0,    scale: 1,   opacity: 0, duration: 1.0 },
      right:  { x: 120,  y: 0,    scale: 1,   opacity: 0, duration: 1.0 },
      scale:  { x: 0,    y: 0,    scale: 0.7, opacity: 0, duration: 1.1 },
      fade:   { x: 0,    y: 0,    scale: 1,   opacity: 0, duration: 0.8 },
      up:     { x: 0,    y: 60,   scale: 1,   opacity: 0, duration: 0.9 },
    };

    document.querySelectorAll("[data-reveal]").forEach((el) => {
      const dir = el.dataset.reveal || "up";
      const cfg = directionConfig[dir] || directionConfig.up;
      const start = el.dataset.revealStart || "top 88%";
      const toggleAction = el.dataset.revealToggle || "play none none none";

      gsap.fromTo(
        el,
        { x: cfg.x, y: cfg.y, scale: cfg.scale, opacity: 0 },
        {
          x: 0, y: 0, scale: 1, opacity: 1,
          duration: cfg.duration,
          ease: "power3.out",
          scrollTrigger: {
            trigger: el,
            start,
            toggleActions: toggleAction,
          },
        }
      );
    });

    // ▸ Stagger groups (data-reveal-stagger)
    document.querySelectorAll("[data-reveal-stagger]").forEach((parent) => {
      const children = parent.children;
      if (!children.length) return;

      const dir = parent.dataset.revealDir || "up";
      const cfg = directionConfig[dir] || directionConfig.up;
      const start = parent.dataset.revealStart || "top 88%";

      gsap.fromTo(
        children,
        { x: cfg.x, y: cfg.y, scale: cfg.scale, opacity: 0 },
        {
          x: 0, y: 0, scale: 1, opacity: 1,
          duration: 0.7,
          stagger: 0.1,
          ease: "power2.out",
          scrollTrigger: {
            trigger: parent,
            start,
            toggleActions: "play none none none",
          },
        }
      );
    });

    // ▸ Pinning sections (data-pin)
    document.querySelectorAll("[data-pin]").forEach((section) => {
      const pinDuration = section.dataset.pinDuration || false;

      ScrollTrigger.create({
        trigger: section,
        start: "top top",
        end: pinDuration ? `+=${pinDuration}` : "bottom top",
        pin: true,
        pinSpacing: true,
        anticipatePin: 1,
      });
    });

    // ▸ Parallax backgrounds (data-parallax-bg)
    document.querySelectorAll("[data-parallax-bg]").forEach((el) => {
      const speed = parseFloat(el.dataset.parallaxBg) || 0.3;
      gsap.fromTo(
        el,
        { y: 0 },
        {
          y: () => el.offsetHeight * speed * -1,
          ease: "none",
          scrollTrigger: {
            trigger: el.parentElement || el,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        }
      );
    });

    // ▸ Números contadores (data-count-to)
    document.querySelectorAll("[data-count-to]").forEach((el) => {
      const targetValue = parseFloat(el.dataset.countTo);
      if (isNaN(targetValue)) return;
      const suffix = el.dataset.countSuffix || "";
      const prefix = el.dataset.countPrefix || "";
      const duration = el.dataset.countDuration
        ? parseFloat(el.dataset.countDuration)
        : 2;

      el.textContent = prefix + "0" + suffix;

      const counter = { value: 0 };
      gsap.to(counter, {
        value: targetValue,
        duration,
        ease: "power2.out",
        scrollTrigger: {
          trigger: el,
          start: "top 90%",
        },
        onUpdate: () => {
          const display =
            targetValue >= 100
              ? Math.round(counter.value)
              : counter.value.toFixed(0);
          el.textContent = prefix + display + suffix;
        },
      });
    });

    // ▸ Timeline de parallax global (capas de fondo)
    document.querySelectorAll("[data-parallax-layer]").forEach((el) => {
      const speed = parseFloat(el.dataset.parallaxLayer) || 0.2;
      gsap.to(el, {
        y: () => (el.offsetHeight * speed * -1),
        ease: "none",
        scrollTrigger: {
          trigger: el.closest("section") || document.body,
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        },
      });
    });

    // ▸ Background morph entre secciones
    // Cambia el color de fondo suavemente según la sección visible
    const bgSections = document.querySelectorAll("[data-bg-color]");
    if (bgSections.length > 0) {
      bgSections.forEach((section) => {
        const targetColor = section.dataset.bgColor;
        ScrollTrigger.create({
          trigger: section,
          start: "top center",
          end: "bottom center",
          onEnter: () => {
            gsap.to("body", {
              backgroundColor: targetColor,
              duration: 0.6,
              ease: "power2.out",
            });
          },
          onEnterBack: () => {
            gsap.to("body", {
              backgroundColor: targetColor,
              duration: 0.6,
              ease: "power2.out",
            });
          },
        });
      });
    }
  }

  // Esperar DOM
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupAnimations);
  } else {
    setupAnimations();
  }

  // ── Refresh en resize ───────────────────────────────────
  let resizeTimer;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ScrollTrigger.refresh();
    }, 250);
  });
</script>
