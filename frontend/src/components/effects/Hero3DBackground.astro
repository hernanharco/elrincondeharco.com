<div class="hero-3d-bg absolute inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
  <canvas id="hero-3d-canvas" class="absolute inset-0 w-full h-full"></canvas>
</div>

<script>
  (function init() {
    const canvas = document.getElementById('hero-3d-canvas');
    if (!canvas || !canvas.getContext) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w, h;
    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // ── Partículas brillantes ─────────────────────────────────
    const particles = [];
    const COUNT = 60;

    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        r: 1.5 + Math.random() * 3,
        alpha: 0.1 + Math.random() * 0.4,
        alphaSpeed: 0.005 + Math.random() * 0.015,
        alphaDir: 1,
      });
    }

    // ── Conexiones ────────────────────────────────────────────
    function drawLines() {
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 200) {
            const alpha = (1 - dist / 200) * 0.15;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(251, 191, 36, ${alpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
    }

    // ── Mouse tracking ────────────────────────────────────────
    let mouseX = 0, mouseY = 0;
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    // ── Animación ─────────────────────────────────────────────
    function animate() {
      ctx.clearRect(0, 0, w, h);

      // Actualizar partículas
      particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;

        // Rebote en bordes
        if (p.x < 0 || p.x > w) p.vx *= -1;
        if (p.y < 0 || p.y > h) p.vy *= -1;

        // Pulso de brillo
        p.alpha += p.alphaSpeed * p.alphaDir;
        if (p.alpha > 0.5 || p.alpha < 0.05) p.alphaDir *= -1;

        // Atracción suave al mouse
        const dx = mouseX - p.x;
        const dy = mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 300) {
          p.vx += dx * 0.00005;
          p.vy += dy * 0.00005;
        }
      });

      drawLines();

      // Dibujar partículas
      particles.forEach(p => {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(251, 191, 36, ${p.alpha})`;
        ctx.fill();

        // Glow
        if (p.alpha > 0.2) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(251, 191, 36, ${p.alpha * 0.1})`;
          ctx.fill();
        }
      });

      requestAnimationFrame(animate);
    }

    animate();
  })();
</script>
