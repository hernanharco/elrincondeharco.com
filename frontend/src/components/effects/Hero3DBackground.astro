<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
  <!-- Gradiente base oscuro -->
  <div class="absolute inset-0 bg-[#060606]"></div>
  
  <!-- Orbes de luz animados (sutiles) -->
  <div class="absolute top-1/4 -left-1/4 w-[600px] h-[600px] rounded-full bg-amber-500/5 blur-[120px] animate-pulse-slow"></div>
  <div class="absolute bottom-1/4 -right-1/4 w-[500px] h-[500px] rounded-full bg-orange-600/5 blur-[100px] animate-pulse-slower"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-amber-400/3 blur-[150px] animate-pulse-slowest"></div>
  
  <!-- Grid líneas sutiles -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(251,191,36,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(251,191,36,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
</div>

<style>
  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }
  @keyframes pulse-slower {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.15); opacity: 0.6; }
  }
  @keyframes pulse-slowest {
    0%, 100% { transform: translateX(-50%) translateY(-50%) scale(1); opacity: 0.2; }
    50% { transform: translateX(-50%) translateY(-50%) scale(1.05); opacity: 0.4; }
  }
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
  .animate-pulse-slower { animation: pulse-slower 12s ease-in-out infinite; }
  .animate-pulse-slowest { animation: pulse-slowest 15s ease-in-out infinite; }
</style>
