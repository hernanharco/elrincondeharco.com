---
import type { SiteSettingsResponse } from '$lib/types';
import { fetchSSR } from '$lib/api';
import { fallbackSiteSettings } from '$lib/fallback-data';

const apiData = await fetchSSR<SiteSettingsResponse>('/site-settings/latest/');
const settings: SiteSettingsResponse = apiData ?? fallbackSiteSettings;

const contactEmail = settings.contact_email || 'hernan.harco@gmail.com';
const linkedinUrl = settings.social_networks?.linkedin || 'https://www.linkedin.com/in/hernan-harco/';
---

<section id="contacto" data-reveal="scale" class="py-24 bg-zinc-900 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_right,_rgba(251,191,36,0.08)_0%,_transparent_60%)] pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_left,_rgba(251,191,36,0.04)_0%,_transparent_60%)] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <h2 class="text-3xl md:text-5xl font-bold mb-6">
      ¿Listo para construir <span class="text-amber-400">algo grande</span>?
    </h2>
    <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-4 leading-relaxed">
      Tenés la idea, yo tengo la experiencia para hacerla realidad. <br class="hidden sm:block" />
      Trabajemos juntos para crear una solución que marque la diferencia.
    </p>

    <!-- Trust indicators -->
    <div class="flex flex-wrap justify-center gap-8 mb-10 text-sm text-gray-500">
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
        Respuesta en 24h
      </span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
        Presupuesto sin compromiso
      </span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
        Soporte post-entrega
      </span>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href={`mailto:${contactEmail}`}
        class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-600 text-black font-bold rounded-xl hover:from-amber-400 hover:to-orange-500 transition-all duration-300 shadow-lg hover:shadow-amber-500/25 text-lg group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        Enviar Correo
      </a>
      <a
        href={linkedinUrl}
        target="_blank"
        class="inline-flex items-center gap-3 px-6 py-4 border border-white/20 text-white font-medium rounded-xl hover:bg-white/5 transition-colors text-lg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
    </div>

    <p class="text-gray-600 text-xs mt-8">
      O escribime directo a <a href={`mailto:${contactEmail}`} class="text-amber-400/60 hover:text-amber-400 transition-colors underline underline-offset-2">{contactEmail}</a>
    </p>
  </div>
</section>
