---
import type { HeroResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackHero } from '$lib/fallback-data';

const apiData = await fetchSSR<HeroResponse>('/heroes/latest/');
const data: HeroResponse = apiData ?? fallbackHero;

// Función para forzar la descarga en URLs de Cloudinary
const getDownloadUrl = (url: string | null | undefined) => {
  if (!url) return '#';
  if (url.includes('cloudinary.com')) {
    if (url.includes('fl_attachment:')) return url;
    if (url.includes('/fl_attachment/')) return url;
    return url.replace('/upload/', '/upload/fl_attachment/');
  }
  return url;
};
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black text-white">
  <div class="absolute inset-0 z-0">
    {data.background_image ? (
      <img src={optimizeImage(data.background_image, 1080, 30)} alt="Background" class="w-full h-full object-cover opacity-20 transition-opacity duration-1000" fetchpriority="high" />
    ) : (
      <img src={optimizeImage('https://images.unsplash.com/photo-1761599821310-da0d6356b4f3?q=80&w=1080', 1080, 30)} alt="Default Background" class="w-full h-full object-cover opacity-10" fetchpriority="high" />
    )}
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div>
      <h2 class="text-amber-500 font-medium tracking-wide text-lg mb-4 uppercase">{data.title}</h2>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 text-white">{data.subtitle}</h1>
      <p class="max-w-2xl mx-auto text-xl text-gray-300 mb-10 leading-relaxed">{data.description}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#contact" class="inline-flex items-center px-8 py-3 border border-transparent text-base font-bold rounded-full text-black bg-amber-400 hover:bg-amber-500 transition-colors shadow-[0_0_20px_rgba(251,191,36,0.3)] active:scale-95">
          {data.contact_button_text}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>

        {data.cv_url && (
          <a href={getDownloadUrl(data.cv_url)} target="_blank" rel="noopener noreferrer" download class="inline-flex items-center px-8 py-3 border border-white/20 text-base font-medium rounded-full text-white hover:bg-white/10 transition-colors backdrop-blur-sm hover:border-amber-400/50 group">
            {data.cv_button_text}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-y-0.5 transition-transform"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce opacity-50 hover:opacity-100 transition-opacity">
    <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center pt-2">
      <div class="w-1 h-3 bg-amber-400 rounded-full"></div>
    </div>
  </div>
</section>
