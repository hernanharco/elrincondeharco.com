      <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-8 hover:bg-zinc-900/80 hover:border-amber-500/20 transition-all duration-500">
        <svg class="absolute top-4 right-6 text-amber-500/10 w-12 h-12" viewBox="0 0 24 24" fill="currentColor">
