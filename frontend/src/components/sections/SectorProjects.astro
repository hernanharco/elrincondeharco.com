---
// SectorProjects.astro — Unifica Sectores + Proyectos
// Usa datos de fallback (los sectores se editan en /admin y
// se actualiza el fallback cuando hay cambios)

import { optimizeImage } from '$lib/api';
import { fallbackProjects, fallbackSectors, fallbackShowrooms } from '$lib/fallback-data';

// ── Usar datos de respaldo (siempre disponibles) ───────────
const allProjects = fallbackProjects;

// Template necesita sectores como variable para renderizar los botones
const sectores = fallbackSectors;

// ── Mapa: sector → títulos de proyectos ────────────────────
// Como fallbackSectors no tiene project_ids reales, usamos
// el mapeo por nombre de sector (compatible con el admin)
const sectorProjectMap: Record<number, string[]> = {
  1: ['Café Mi Tierra'],                     // Hostelería
  2: ['miniCRM Ghogares'],                    // Inmobiliaria
  3: ['Tapicería Moderna'],                   // Talleres
  4: ['CoreAppointment'],                     // Salud
  5: ['Nanatha'],                             // Belleza
  6: [],                                      // Logística
};

// ── Showroom items como complemento ────────────────────────
const showroomComplement: Record<number, typeof fallbackShowrooms> = {
  1: fallbackShowrooms.filter(x => x.title.includes('Gastronómica') || x.title.includes('Restauran')),
  2: [],
  3: fallbackShowrooms.filter(x => x.title.includes('Taller')),
  4: fallbackShowrooms.filter(x => x.title.includes('Clínica') || x.title.includes('Doctora')),
  5: fallbackShowrooms.filter(x => x.title.includes('Estética') || x.title.includes('Beauty')),
  6: fallbackShowrooms.filter(x => x.title.includes('Prixline')),
};

// ── Serializar para el cliente ─────────────────────────────
const sectorData = JSON.stringify({
  sectores: fallbackSectors.map(s => ({
    id: s.id,
    name: s.name,
    client: s.client_name,
    icon: s.icon_path,
    gradient: s.color_gradient,
    description: s.description,
  })),
  projects: allProjects,
  projectTitles: sectorProjectMap,
  showroomBySector: Object.fromEntries(
    Object.entries(showroomComplement).map(([key, items]) => [
      key,
      items.map(s => ({ title: s.title, description: s.description, image_url: s.image_url, demo_url: s.deploy_url }))
    ])
  ),
});
---

<section id="experiencia" class="py-24 bg-zinc-950 text-white relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(6,182,212,0.03)_0%,_transparent_60%)] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-amber-400 text-xs font-medium tracking-[0.25em] uppercase mb-3">Experiencia</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Seleccioná tu <span class="text-amber-400">rubro</span>
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-lg">
        Tocá tu industria y descubrí lo que construimos para negocios como el tuyo.
      </p>
    </div>

    <!-- Sector Selector -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-16" id="sector-grid">
      {sectores.map((s) => (
        <button
          onclick={`selectSector('${s.id}')`}
          class="sector-btn group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-6 text-center
            hover:border-cyan-400/30 hover:bg-zinc-900/80
            transition-all duration-500 hover:-translate-y-1 cursor-pointer active:scale-95"
        >
          <div
            class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20
              flex items-center justify-center mx-auto mb-4
              group-hover:bg-cyan-500/20 group-hover:border-cyan-400/30
              transition-all duration-500"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
              fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="text-amber-400 transition-colors duration-500"
            ><path d={s.icon_path} /></svg>
          </div>
          <h3 class="font-bold text-white text-sm">{s.name}</h3>
          <p class="text-gray-600 text-xs mt-1">{s.client_name}</p>
        </button>
      ))}
    </div>

    <!-- Project Display Area -->
    <div id="project-display" class="min-h-[280px]">
      <!-- Projects grid (con perspective para el 3D) -->
      <div
        id="projects-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5"
        style="perspective: 900px; perspective-origin: 50% -10%;"
      ></div>
    </div>
  </div>
</section>

<!-- Datos serializados (URI-encoded para seguridad en HTML) -->
<div id="sector-data" data-json={encodeURIComponent(sectorData)} style="display:none" aria-hidden="true"></div>

<script>
  // ── Cargar datos ───────────────────────────────────────────
  const DATA_EL = document.getElementById("sector-data");
  if (!DATA_EL) { console.error("[SectorProjects] Missing data element"); }
  const DATA = DATA_EL ? JSON.parse(decodeURIComponent(DATA_EL.dataset.json)) : null;
  const { sectores, projects, projectTitles, showroomBySector } = DATA;

  const grid = document.getElementById("projects-grid");
  let activeSector = null;

  // ── Animación 3D real (vía CSS classes) ────────────────────
  function animateCardIn(card, delay = 0) {
    // Estado inicial: oculto con 3D (classes del CSS)
    card.classList.add("card-enter-from");

    // Doble rAF: garantiza que el navegador pinte el estado inicial
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        setTimeout(() => {
          card.classList.remove("card-enter-from");
          card.classList.add("card-enter-to");
        }, delay);
      });
    });
  }

  function animateCardOut(card, delay = 0) {
    setTimeout(() => {
      card.classList.remove("card-enter-to");
      card.classList.add("card-exit");
    }, delay);
  }

  // ── Renderizar proyectos para un sector ────────────────────
  function renderProjects(sectorId) {
    const titles = projectTitles[sectorId] || [];
    const matched = projects.filter((p) => titles.includes(p.title));
    const showroomItems = showroomBySector[sectorId] || [];
    const combined = [...matched, ...showroomItems];

    // Si hay cards actuales, animar salida primero
    const currentCards = grid.querySelectorAll(".project-card");
    if (currentCards.length > 0) {
      currentCards.forEach((card, i) => animateCardOut(card, i * 60));
      setTimeout(() => renderNew(sectorId, combined), currentCards.length * 60 + 500);
    } else {
      renderNew(sectorId, combined);
    }
  }

  function renderNew(sectorId, combined) {
    grid.innerHTML = "";

    if (combined.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full text-center py-12">
          <div class="w-16 h-16 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-cyan-400"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <p class="text-gray-400 mb-2">Proyecto próximo — contactame para más información.</p>
          <a href="#contacto" class="inline-flex items-center gap-2 mt-2 px-5 py-2.5 bg-amber-500 hover:bg-amber-400 text-black text-sm font-bold rounded-xl transition-all">Trabajemos juntos →</a>
        </div>`;
      return;
    }

    // Crear cards
    combined.forEach((item, idx) => {
      const card = document.createElement("div");
      card.className = "project-card bg-white/[0.03] border border-white/[0.06] rounded-2xl overflow-hidden hover:bg-white/[0.06] hover:border-cyan-400/20 group";

      card.innerHTML = `
        <div class="relative h-48 overflow-hidden">
          ${item.image_url
            ? `<img src="${item.image_url}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />`
            : `<div class="w-full h-full bg-gradient-to-br from-amber-500/20 to-orange-600/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/10 scale-[3]"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
              </div>`
          }
        </div>
        <div class="p-5">
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">${item.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-2">${item.description || ''}</p>
          <div class="flex items-center gap-4 pt-4 border-t border-white/5">
            ${item.demo_url
              ? `<a href="${item.demo_url}" target="_blank" class="text-xs font-medium text-amber-400 hover:text-cyan-400 transition-colors">Ver Demo →</a>`
              : ''
            }
            ${item.github_url
              ? `<a href="${item.github_url}" target="_blank" class="text-xs font-medium text-gray-500 hover:text-cyan-400 transition-colors">Código</a>`
              : ''
            }
          </div>
        </div>
      `;

      grid.appendChild(card);

      // Animar entrada 3D con stagger
      animateCardIn(card, idx * 150);
    });
  }

  // ── Selector de sector ─────────────────────────────────────
  window.selectSector = function (sectorId) {
    if (sectorId === activeSector) return;
    activeSector = sectorId;

    // Actualizar UI de botones
    document.querySelectorAll(".sector-btn").forEach((btn) => {
      const isActive = btn.getAttribute("onclick")?.includes(sectorId);
      btn.classList.toggle("sector-active", isActive);
    });

    renderProjects(sectorId);
  };

  // ── Opción A: Auto-seleccionar primer rubro al entrar ──────
  function initAutoSelect() {
    if (!sectores || sectores.length === 0) return;

    const section = document.getElementById("experiencia");
    if (!section) return;

    // Intersection Observer: dispara cuando la sección es visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Seleccionar Hostelería (primer sector)
            const firstSector = sectores[0].id;
            window.selectSector(firstSector);
            observer.disconnect(); // Solo una vez
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(section);
  }

  // Iniciar cuando el DOM esté listo
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAutoSelect);
  } else {
    initAutoSelect();
  }
</script>

<style>
  .project-card {
    will-change: transform, opacity, filter;
    backface-visibility: hidden;
  }

  /* ── Animación 3D de entrada ──────────────────────────── */
  .card-enter-from {
    opacity: 0;
    transform: perspective(600px) rotateX(15deg) rotateY(-35deg) scale(0.55) translateZ(-150px);
    filter: blur(6px);
    transition: none !important;
  }

  .card-enter-to {
    opacity: 1;
    transform: perspective(600px) rotateX(0deg) rotateY(0deg) scale(1) translateZ(0);
    filter: blur(0);
    transition: all 0.7s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  /* ── Animación 3D de salida ───────────────────────────── */
  .card-exit {
    opacity: 0;
    transform: perspective(600px) rotateX(-10deg) rotateY(45deg) scale(0.4) translateZ(-200px);
    filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.6, 0, 0.4, 1);
  }

  /* ── Sector activo ────────────────────────────────────── */
  .sector-btn.sector-active {
    border-color: rgba(6, 182, 212, 0.4) !important;
    background: rgba(6, 182, 212, 0.08) !important;
    box-shadow: 0 0 30px -5px rgba(6, 182, 212, 0.15);
  }
  .sector-btn.sector-active svg {
    color: #06b6d4 !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none !important; }
    .card-enter-from, .card-enter-to, .card-exit {
      transition: none !important;
    }
    .card-enter-from {
      opacity: 0;
      transform: none;
      filter: none;
    }
    .card-enter-to {
      opacity: 1;
    }
    .card-exit {
      opacity: 0;
    }
  }
</style>
