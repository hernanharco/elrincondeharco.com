---
import type { StackResponse } from '$lib/types';
import { fetchSSR } from '$lib/api';
import { fallbackStacks } from '$lib/fallback-data';

const apiItems = await fetchSSR<StackResponse[]>('/stacks/');
const items = apiItems ?? fallbackStacks;
const categories = ['Frontend', 'Backend', 'DevOps', 'Herramientas'];

// Niveles de poder por categoría
const tierConfig: Record<string, { tier: string; label: string; color: string; power: number }> = {
  Frontend: { tier: 'S', label: 'S — Maestría Absoluta', color: 'from-amber-400 to-orange-500', power: 95 },
  Backend: { tier: 'A', label: 'A — Alto Dominio', color: 'from-teal-400 to-cyan-500', power: 88 },
  DevOps: { tier: 'B', label: 'B — Sólido', color: 'from-blue-400 to-indigo-500', power: 75 },
  Herramientas: { tier: 'A', label: 'A — Alto Dominio', color: 'from-purple-400 to-pink-500', power: 85 },
};

// Nivel individual por tecnología (poder específico)
const techPower: Record<string, number> = {
  HTML5: 98, CSS3: 95, 'Tailwind CSS': 92, JavaScript: 90, TypeScript: 88,
  React: 85, Astro: 82, 'Next.js': 78,
  Python: 92, FastAPI: 90, Django: 80, 'API REST': 92, JWT: 85,
  MongoDB: 78, NEON: 82,
  Docker: 75, Git: 95, GitHub: 90, Vercel: 85, Render: 70,
  'VS Code': 95, Postman: 88, 'IA & LLMs': 85, Optimización: 90,
};

const iconPaths: Record<string, string> = {
  layers: '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
  monitor: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
  'hard-drive': '<line x1="22" x2="2" y1="12" y2="12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" x2="6.01" y1="16" y2="16"/><line x1="10" x2="10.01" y1="16" y2="16"/>',
  settings: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
  earth: '<path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3v0a2 2 0 0 1 2 2v0c0 1.1.9 2 2 2v0a2 2 0 0 0 2-2v0c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2v0a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/>',
  palette: '<circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.5 1.5-1.5 0-.4-.2-.8-.5-1.1-.3-.3-.5-.7-.5-1.1 0-.93.75-1.5 1.5-1.5h2.5c4.42 0 8-3.58 8-8 0-4.42-3.58-8-8-8z"/>',
  'file-code-2': '<path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m5 12-3 3 3 3"/><path d="m9 18 3-3-3-3"/>',
  atom: '<circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c-4.5 4.5-11.9 4.5-16.4 0s-4.5-11.9 0-16.4 11.9-4.5 16.4 0"/><path d="M3.8 20.2c-4.5-4.5-4.5-11.9 0-16.4 4.5-4.5 11.9-4.5 16.4 0"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/>',
  server: '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  container: '<path d="M22 7.7c0-.6-.4-1.2-.8-1.5l-8.5-5.2c-.4-.3-1-.3-1.4 0l-8.5 5.2c-.4.3-.8.9-.8 1.5v8.6c0 .6.4 1.2.8 1.5l8.5 5.2c.4.3 1 .3 1.4 0l8.5-5.2c.4-.3.8-.9.8-1.5V7.7z"/><path d="M12 12 2.3 7.3"/><path d="M12 12 12 22"/>',
  'git-branch': '<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  cloud: '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>',
  'code-2': '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4 5 16"/>',
  send: '<path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4Z"/>',
  'brain-circuit': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M11.5 15v2"/><path d="M12 9v-2"/>',
  gauge: '<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
  'layout-template': '<rect width="18" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/>',
  triangle: '<path d="M21.5 20.5 12 3 2.5 20.5z"/>',
};

function pascalToKebab(name: string): string {
  return name.replace(/([A-Z])/g, (m, l, o) => (o > 0 ? '-' + l.toLowerCase() : l.toLowerCase())).replace(/(\d+)/g, '-$1').replace(/--+/g, '-').replace(/-+$/, '');
}

function getIconSvg(iconName: string, size: number = 24): string {
  const kebab = pascalToKebab(iconName);
  const path = iconPaths[kebab] || iconPaths['layers'];
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}

function getPower(tech: StackResponse): number {
  return techPower[tech.name] || tierConfig[tech.category]?.power || 70;
}

function powerColor(power: number): string {
  if (power >= 90) return 'from-amber-400 to-orange-500';
  if (power >= 80) return 'from-teal-400 to-cyan-500';
  if (power >= 70) return 'from-blue-400 to-indigo-500';
  return 'from-zinc-400 to-zinc-500';
}

function powerGlow(power: number): string {
  if (power >= 90) return 'shadow-amber-500/20';
  if (power >= 80) return 'shadow-teal-500/20';
  if (power >= 70) return 'shadow-blue-500/20';
  return 'shadow-zinc-500/10';
}
---

<section id="stack" class="py-24 bg-zinc-950 text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Arsenal <span class="text-amber-400">Técnico</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        Power levels actualizados. Tecnologías que domino y uso en producción.
      </p>
    </div>

    <!-- Inputs ocultos para selección de tier -->
    <input type="radio" name="stack-tier" id="tier-Frontend" class="hidden" checked>
    <input type="radio" name="stack-tier" id="tier-Backend" class="hidden">
    <input type="radio" name="stack-tier" id="tier-DevOps" class="hidden">
    <input type="radio" name="stack-tier" id="tier-Herramientas" class="hidden">

    <!-- Selector de Tabs -->
    <div class="stack-tabs flex flex-wrap justify-center gap-3 mb-12">
      {categories.map(cat => {
        const cfg = tierConfig[cat];
        return (
          <label
            for={`tier-${cat}`}
            class="tier-tab px-5 py-2.5 rounded-xl text-sm font-bold transition-all duration-300 cursor-pointer border border-white/10 bg-white/5 text-gray-400 hover:border-white/30 hover:text-white"
          >
            <span class="mr-2 inline-flex items-center justify-center w-6 h-6 rounded-lg bg-gradient-to-br {cfg.color} text-black text-xs font-black">{cfg.tier}</span>
            {cat}
          </label>
        );
      })}
    </div>

    <!-- Contenedor de tiers -->
    <div class="stack-content">
      {categories.map(cat => {
        const cfg = tierConfig[cat];
        const techs = items.filter(t => t.category === cat);
        const totalPower = cfg.power;
        return (
          <div class={`tier-content tier-${cat}`}>
            <div class="mb-8 flex items-center gap-4">
              <span class="text-5xl font-black bg-gradient-to-br {cfg.color} bg-clip-text text-transparent">{cfg.tier}</span>
              <div>
                <span class="text-sm text-gray-500 uppercase tracking-widest">{cfg.label}</span>
                <div class="flex items-center gap-3 mt-1">
                  <div class="h-2 w-48 bg-zinc-800 rounded-full overflow-hidden">
                    <div class="h-full rounded-full bg-gradient-to-r {cfg.color}" style={`width: ${totalPower}%`}></div>
                  </div>
                  <span class="text-sm font-bold text-amber-400 tabular-nums">{totalPower}%</span>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {techs.map(tech => {
                const pw = getPower(tech);
                const pColor = powerColor(pw);
                const pGlow = powerGlow(pw);
                return (
                  <div class="group relative bg-zinc-900/50 border border-white/5 rounded-xl p-4 hover:border-white/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg {`hover:${pGlow}`}">
                    <div class="flex items-center gap-3 mb-3">
                      <div class={`p-2 rounded-lg bg-white/5 ${tech.color}`}>
                        <span set:html={getIconSvg(tech.icon, 20)} />
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <h3 class="font-bold text-white text-sm">{tech.name}</h3>
                          <span class="text-xs font-mono text-amber-400/60 tabular-nums">{pw}%</span>
                        </div>
                        <p class="text-xs text-gray-500 truncate">{tech.description}</p>
                      </div>
                    </div>
                    <div class="h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                      <div class="h-full rounded-full bg-gradient-to-r {pColor} group-hover:shadow-[0_0_8px_rgba(251,191,36,0.3)]" style={`width: ${pw}%`}></div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <div class="text-center mt-12">
      <p class="text-zinc-500 text-sm">
        · Niveles basados en experiencia y uso en proyectos reales ·
      </p>
    </div>
  </div>
</section>

<style is:global>
  /* Ocultar todos los tiers por defecto */
  .tier-content { display: none; }

  /* Mostrar solo el tier seleccionado */
  #tier-Frontend:checked ~ .stack-content .tier-Frontend { display: block; }
  #tier-Backend:checked  ~ .stack-content .tier-Backend  { display: block; }
  #tier-DevOps:checked   ~ .stack-content .tier-DevOps   { display: block; }
  #tier-Herramientas:checked ~ .stack-content .tier-Herramientas { display: block; }

  /* Tab activo */
  #tier-Frontend:checked ~ .stack-tabs .tier-tab[for="tier-Frontend"],
  #tier-Backend:checked ~ .stack-tabs .tier-tab[for="tier-Backend"],
  #tier-DevOps:checked ~ .stack-tabs .tier-tab[for="tier-DevOps"],
  #tier-Herramientas:checked ~ .stack-tabs .tier-tab[for="tier-Herramientas"] {
    background: rgb(251 191 36) !important;
    color: black !important;
    border-color: rgb(251 191 36) !important;
    box-shadow: 0 0 20px rgba(251,191,36,0.3);
  }
</style>
