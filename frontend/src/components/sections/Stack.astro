---
import type { StackResponse } from '$lib/types';
import { fetchSSR } from '$lib/api';
import { fallbackStacks } from '$lib/fallback-data';

const apiItems = await fetchSSR<StackResponse[]>('/stacks/');
const items = apiItems ?? fallbackStacks;
const categories = ['Todos', 'Frontend', 'Backend', 'DevOps', 'Herramientas'];

const iconPaths: Record<string, string> = {
  earth: '<path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3v0a2 2 0 0 1 2 2v0c0 1.1.9 2 2 2v0a2 2 0 0 0 2-2v0c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2v0a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/>',
  palette: '<circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.5 1.5-1.5 0-.4-.2-.8-.5-1.1-.3-.3-.5-.7-.5-1.1 0-.93.75-1.5 1.5-1.5h2.5c4.42 0 8-3.58 8-8 0-4.42-3.58-8-8-8z"/>',
  'file-code-2': '<path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m5 12-3 3 3 3"/><path d="m9 18 3-3-3-3"/>',
  atom: '<circle cx="12" cy="12" r="1"/><path d="M20.2 20.2c-4.5 4.5-11.9 4.5-16.4 0s-4.5-11.9 0-16.4 11.9-4.5 16.4 0"/><path d="M3.8 20.2c-4.5-4.5-4.5-11.9 0-16.4 4.5-4.5 11.9-4.5 16.4 0"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  'layout-template': '<rect width="18" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/>',
  terminal: '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/>',
  layers: '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
  server: '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  container: '<path d="M22 7.7c0-.6-.4-1.2-.8-1.5l-8.5-5.2c-.4-.3-1-.3-1.4 0l-8.5 5.2c-.4.3-.8.9-.8 1.5v8.6c0 .6.4 1.2.8 1.5l8.5 5.2c.4.3 1 .3 1.4 0l8.5-5.2c.4-.3.8-.9.8-1.5V7.7z"/><path d="M12 12 2.3 7.3"/><path d="M12 12 12 22"/>',
  'git-branch': '<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  triangle: '<path d="M21.5 20.5 12 3 2.5 20.5z"/>',
  cloud: '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>',
  'code-2': '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4 5 16"/>',
  send: '<path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4Z"/>',
  'brain-circuit': '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M11.5 15v2"/><path d="M12 9v-2"/>',
  gauge: '<path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/>',
  monitor: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
  'hard-drive': '<line x1="22" x2="2" y1="12" y2="12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/><line x1="6" x2="6.01" y1="16" y2="16"/><line x1="10" x2="10.01" y1="16" y2="16"/>',
  settings: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>',
};

const categoryIcons: Record<string, string> = {
  Frontend: 'monitor',
  Backend: 'hard-drive',
  DevOps: 'layers',
  Herramientas: 'settings',
};

function pascalToKebab(name: string): string {
  return name
    .replace(/([A-Z])/g, (m, l, o) => (o > 0 ? '-' + l.toLowerCase() : l.toLowerCase()))
    .replace(/(\d+)/g, '-$1')
    .replace(/--+/g, '-')
    .replace(/-+$/, '');
}

function getIconSvg(iconName: string, size: number = 24): string {
  const kebab = pascalToKebab(iconName);
  const path = iconPaths[kebab] || iconPaths['layers'];
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}
---

<section id="stack" class="py-24 bg-zinc-950 text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <input type="radio" name="stack-category" id="cat-Todos" class="hidden" checked>
    <input type="radio" name="stack-category" id="cat-Frontend" class="hidden">
    <input type="radio" name="stack-category" id="cat-Backend" class="hidden">
    <input type="radio" name="stack-category" id="cat-DevOps" class="hidden">
    <input type="radio" name="stack-category" id="cat-Herramientas" class="hidden">

    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="space-y-2">
        <h2 class="text-3xl md:text-5xl font-bold">
          Arsenal <span class="text-amber-400">Técnico</span>
        </h2>
        <p class="text-gray-400 max-w-lg text-lg">
          Herramientas modernas para soluciones rápidas y escalables.
        </p>
      </div>

      <div class="flex flex-wrap gap-2 stack-filters">
        {categories.map(cat => (
          <label
            for={`cat-${cat}`}
            class="cat-btn px-4 py-2 rounded-full text-sm font-medium transition-colors duration-300 flex items-center gap-2 border bg-white/5 text-gray-400 border-white/10 hover:border-white/30 hover:text-white cursor-pointer"
          >
            {cat !== 'Todos' && <span set:html={getIconSvg(categoryIcons[cat], 16)} />}
            {cat}
          </label>
        ))}
      </div>
    </div>

    {items.length === 0 && (
      <div class="col-span-full text-center py-8">
        <p class="text-zinc-500">No hay tecnologías en esta categoría</p>
      </div>
    )}

    <div class="stack-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {items.map(tech => (
        <div
          data-category={tech.category}
          class="stack-item group relative p-4 h-32 flex flex-col justify-between bg-zinc-900/50 rounded-xl border border-white/5 transition-shadow duration-300 hover:-translate-y-1 {tech.border} {tech.glow}"
        >
          <div class="flex justify-between items-start">
            <div class="p-2 rounded-lg bg-white/5 {tech.color}">
              <span set:html={getIconSvg(tech.icon, 24)} />
            </div>
            <span class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">{tech.category}</span>
          </div>
          <div>
            <h3 class="font-bold text-white tracking-wide">{tech.name}</h3>
            <p class="text-xs text-gray-400 mt-1 line-clamp-1">{tech.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-zinc-500 text-sm">
        transformando arquitecturas complejas en experiencias digitales impecables y escalables.
      </p>
    </div>
  </div>
</section>

<style is:global>
  #cat-Todos:checked ~ .stack-grid .stack-item { display: flex; }
  #cat-Frontend:checked ~ .stack-grid .stack-item[data-category="Frontend"] { display: flex; }
  #cat-Backend:checked ~ .stack-grid .stack-item[data-category="Backend"] { display: flex; }
  #cat-DevOps:checked ~ .stack-grid .stack-item[data-category="DevOps"] { display: flex; }
  #cat-Herramientas:checked ~ .stack-grid .stack-item[data-category="Herramientas"] { display: flex; }

  #cat-Frontend:checked ~ .stack-grid .stack-item:not([data-category="Frontend"]),
  #cat-Backend:checked ~ .stack-grid .stack-item:not([data-category="Backend"]),
  #cat-DevOps:checked ~ .stack-grid .stack-item:not([data-category="DevOps"]),
  #cat-Herramientas:checked ~ .stack-grid .stack-item:not([data-category="Herramientas"]) { display: none; }

  #cat-Todos:checked ~ div .stack-filters .cat-btn[for="cat-Todos"],
  #cat-Frontend:checked ~ div .stack-filters .cat-btn[for="cat-Frontend"],
  #cat-Backend:checked ~ div .stack-filters .cat-btn[for="cat-Backend"],
  #cat-DevOps:checked ~ div .stack-filters .cat-btn[for="cat-DevOps"],
  #cat-Herramientas:checked ~ div .stack-filters .cat-btn[for="cat-Herramientas"] {
    background-color: rgb(251 191 36) !important;
    color: black !important;
    border-color: rgb(251 191 36) !important;
    box-shadow: 0 0 15px rgba(251,191,36,0.4) !important;
  }
</style>
