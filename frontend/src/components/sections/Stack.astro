---
import type { StackResponse } from '$lib/types';
import { fetchSSR } from '$lib/api';
import { fallbackStacks } from '$lib/fallback-data';

const apiItems = await fetchSSR<StackResponse[]>('/stacks/');
const items = apiItems ?? fallbackStacks;
---

<section id="stack" class="py-24 bg-zinc-950 text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="space-y-2">
        <h2 class="text-3xl md:text-5xl font-bold">
          Arsenal <span class="text-amber-400">Técnico</span>
        </h2>
        <p class="text-gray-400 max-w-lg text-lg">
          Herramientas modernas para soluciones rápidas y escalables.
        </p>
      </div>

      <div id="stack-filters" class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <span class="cat-filter inline-block" data-cat={cat}>
            {cat}
          </span>
        ))}
      </div>
    </div>

    <div id="stack-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {items.map(tech => (
        <div data-category={tech.category} class="stack-item">
          <div class={`group relative p-4 h-32 flex flex-col justify-between bg-zinc-900/50 rounded-xl border border-white/5 ${tech.border} ${tech.glow}`}>
            <div class="flex justify-between items-start">
              <div class={`p-2 rounded-lg bg-white/5 ${tech.color}`}>
                <span set:html={getIconSvg(tech.icon, 24)} />
              </div>
              <span class="text-[10px] uppercase tracking-wider text-gray-500 font-semibold">{tech.category}</span>
            </div>
            <div>
              <h3 class="font-bold text-white tracking-wide">{tech.name}</h3>
              <p class="text-xs text-gray-400 mt-1 line-clamp-1">{tech.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-zinc-500 text-sm">
        transformando arquitecturas complejas en experiencias digitales impecables y escalables.
      </p>
    </div>
  </div>
</section>

<script>
  // Stack filters — tiny script, no libraries, no frameworks
  const grid = document.getElementById('stack-grid');
  const filters = document.querySelectorAll('.cat-filter');
  const allItems = grid.querySelectorAll('.stack-item');
  
  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      
      // Update active button style
      filters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Filter items
      allItems.forEach(item => {
        if (cat === 'Todos' || item.dataset.category === cat) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
  
  // Activate "Todos" by default
  filters[0].classList.add('active');
</script>

<style is:global>
  .cat-filter {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.05);
    color: rgb(156 163 175);
    transition: none !important;
  }
  .cat-filter.active {
    background-color: rgb(251 191 36) !important;
    color: black !important;
    border-color: rgb(251 191 36) !important;
    box-shadow: 0 0 15px rgba(251,191,36,0.4) !important;
  }
</style>
