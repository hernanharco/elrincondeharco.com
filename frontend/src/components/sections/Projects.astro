---
import type { ProjectResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackProjects } from '$lib/fallback-data';

const onlyBest = ['Café Mi Tierra', 'Nanatha', 'miniCRM Ghogares'];

const apiItems = await fetchSSR<ProjectResponse[]>('/projects/');
const apiTitles = new Set((apiItems ?? []).map(p => p.title));
const merged = [...(apiItems ?? []), ...fallbackProjects.filter(p => !apiTitles.has(p.title))];
const items = merged.filter(p => onlyBest.includes(p.title));
---

<section id="proyectos" class="min-h-screen flex items-center py-24">
  <div class="w-full max-w-6xl mx-auto px-6">
    <div class="text-center mb-20">
      <p class="text-amber-400 text-xs font-medium tracking-[0.25em] uppercase mb-3">Proyectos</p>
      <h2 class="text-3xl md:text-5xl font-bold text-white">
        Lo que he <span class="text-amber-400">construido</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {items.map(project => (
        <div class="group relative bg-white/[0.03] border border-white/[0.06] rounded-2xl overflow-hidden hover:bg-white/[0.06] hover:border-amber-500/20 transition-all duration-500">
          <div class="relative h-52 overflow-hidden">
            {project.image_url ? (
              <img src={optimizeImage(project.image_url, 600)} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            ) : (
              <div class="w-full h-full bg-gradient-to-br {project.color} flex items-center justify-center">
                <div class="text-white/10 scale-[3]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
                </div>
              </div>
            )}
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-amber-400 transition-colors">{project.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed mb-5 line-clamp-2">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.slice(0, 3).map(tag => (
                <span class="px-2.5 py-1 text-[10px] font-medium rounded-md bg-white/5 border border-white/10 text-gray-500">{tag}</span>
              ))}
            </div>
            <div class="flex items-center gap-4 mt-5 pt-4 border-t border-white/5">
              {project.demo_url && <a href={project.demo_url} target="_blank" class="text-xs font-medium text-amber-400 hover:text-amber-300 transition-colors">Ver Demo →</a>}
              {project.github_url && <a href={project.github_url} target="_blank" class="text-xs font-medium text-gray-500 hover:text-white transition-colors">Código</a>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
