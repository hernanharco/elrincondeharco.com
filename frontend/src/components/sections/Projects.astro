---
import type { ProjectResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackProjects } from '$lib/fallback-data';
import ProjectCard from '../ui/ProjectCard.astro';

// Solo los mejores proyectos
const onlyBest = ['Café Mi Tierra', 'Nanatha', 'miniCRM Ghogares'];

// Merge: datos de API + fallback (evita duplicados por título)
const apiItems = await fetchSSR<ProjectResponse[]>('/projects/');
const apiTitles = new Set((apiItems ?? []).map(p => p.title));
const merged = [...(apiItems ?? []), ...fallbackProjects.filter(p => !apiTitles.has(p.title))];
const items = merged.filter(p => onlyBest.includes(p.title));

// Helper para iconos (solo para el featured card inline)
function getIconSvg(iconName: string, size: number = 24): string {
  const paths: Record<string, string> = {
    coffee: '<path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/>',
  };
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${paths[iconName] || paths.coffee}</svg>`;
}
---

<section id="proyectos" class="py-24 bg-zinc-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Proyectos <span class="text-amber-400">Destacados</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg">
        Soluciones reales que demuestran la capacidad de entrega y calidad técnica.
      </p>
    </div>

    {items.find(p => p.title === 'Café Mi Tierra') ? (
      <>
        <!-- Card Destacada: Café Mi Tierra -->
        <div class="mb-12 group relative bg-gradient-to-br from-amber-900/30 via-zinc-900 to-red-900/20 border border-amber-500/20 rounded-3xl overflow-hidden hover:border-amber-400/40 transition-all duration-500 hover:shadow-[0_0_60px_-15px_rgba(251,191,36,0.2)]">
          <div class="absolute -inset-1 bg-gradient-to-r from-amber-600/20 via-transparent to-red-600/20 opacity-0 group-hover:opacity-100 blur-3xl transition-opacity duration-1000 pointer-events-none"></div>

          <div class="relative grid grid-cols-1 lg:grid-cols-5 gap-0">
            <div class="lg:col-span-2 relative h-64 lg:h-auto bg-gradient-to-br from-amber-800/40 to-red-800/40 flex items-center justify-center overflow-hidden">
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(251,191,36,0.15)_0%,_transparent_70%)]"></div>
              <div class="relative z-10 text-center">
                <div class="text-amber-300/20 scale-[6] mb-4 inline-block">{getIconSvg('coffee', 48)}</div>
                <div class="absolute top-4 left-4">
                  <span class="px-3 py-1.5 bg-amber-500 text-black text-xs font-bold rounded-full tracking-wider uppercase shadow-lg shadow-amber-500/25">✦ Destacado</span>
                </div>
              </div>
              <div class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2 opacity-60">
                {['Three.js', 'GSAP', 'Svelte 5', 'Hono.js'].map(tag => (
                  <span class="px-2 py-1 bg-white/5 backdrop-blur-sm border border-white/10 rounded-md text-[10px] text-white/70 font-mono">{tag}</span>
                ))}
              </div>
            </div>

            <div class="lg:col-span-3 p-8 lg:p-10 flex flex-col justify-center">
              <h3 class="text-2xl lg:text-3xl font-bold text-white mb-3">Café Mi Tierra</h3>
              <p class="text-gray-300 leading-relaxed mb-6 text-base">
                Web corporativa para cafetería/bar con efectos visuales inmersivos (Three.js, GSAP), panel de administración completo, galería interactiva, horarios, reseñas y sistema de contacto.
              </p>

              <div class="flex flex-wrap gap-2 mb-8">
                {['Astro 7', 'Svelte 5', 'Three.js', 'GSAP', 'Hono.js', 'PostgreSQL'].map(tag => (
                  <span class="px-3 py-1 text-xs font-medium rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-300">{tag}</span>
                ))}
              </div>

              <div class="flex items-center gap-4">
                <a href="https://frontend-gray-alpha-wjs0x2ofbn.vercel.app/" target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-amber-500 to-orange-600 text-black font-bold rounded-xl hover:from-amber-400 hover:to-orange-500 transition-all duration-300 shadow-lg hover:shadow-amber-500/25 text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  Ver Demo en Vivo
                </a>
                <a href="https://github.com/hernanharco/cafemitierra" target="_blank" class="inline-flex items-center gap-2 px-4 py-3 border border-white/20 text-white font-medium rounded-xl hover:bg-white/5 transition-colors text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  Código
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Grid con el resto de proyectos -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {items.filter(p => p.title !== 'Café Mi Tierra').map(project => (
            <ProjectCard project={project} />
          ))}
        </div>
      </>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {items.map(project => (
          <ProjectCard project={project} />
        ))}
      </div>
    )}

    <div class="text-center mt-16">
      <a
        href="/showroom"
        class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-600 text-white font-bold rounded-xl hover:from-amber-600 hover:to-orange-700 transition-shadow duration-300 shadow-lg hover:shadow-amber-500/25 group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
        <span>Bocetos de Innovación</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-x-1"
        ><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
