---
import type { AboutResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackAbout } from '$lib/fallback-data';

const apiData = await fetchSSR<AboutResponse>('/abouts/latest/');
const data: AboutResponse = apiData ?? fallbackAbout;
---

<section id="sobre-mi" class="py-20 bg-zinc-900 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold">
        Mi <span class="text-amber-400">Historia</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto text-lg mt-4">
        De Colombia a Asturias. De liderar equipos a construir el futuro de la web.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Timeline -->
      <div class="relative space-y-0">
        <!-- Línea vertical -->
        <div class="absolute left-[19px] top-2 bottom-2 w-0.5 bg-gradient-to-b from-amber-500/50 via-amber-400/30 to-amber-500/50 hidden md:block"></div>

        <!-- Hito 1: Colombia -->
        <div class="relative pl-14 pb-12 group">
          <div class="absolute left-0 top-1 w-10 h-10 rounded-full bg-zinc-800 border-2 border-amber-500/50 flex items-center justify-center group-hover:border-amber-400 group-hover:bg-amber-500/10 transition-all duration-300 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <span class="text-amber-400/60 text-xs font-bold tracking-widest uppercase">2009 — 2020</span>
            <h3 class="text-xl font-bold text-white mt-1 mb-2">Inicios en Colombia</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Empecé mi carrera a los 18 años en Colombia. Durante 11 años trabajé en una empresa donde escalé desde posiciones iniciales hasta formar un equipo de alto rendimiento.
            </p>
          </div>
        </div>

        <!-- Hito 2: Equipo de Oro -->
        <div class="relative pl-14 pb-12 group">
          <div class="absolute left-0 top-1 w-10 h-10 rounded-full bg-zinc-800 border-2 border-amber-500/50 flex items-center justify-center group-hover:border-amber-400 group-hover:bg-amber-500/10 transition-all duration-300 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <span class="text-amber-400/60 text-xs font-bold tracking-widest uppercase">2015 — 2020</span>
            <h3 class="text-xl font-bold text-white mt-1 mb-2">El Equipo de Oro</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Formé y lideré un equipo competitivo y ágil al que llamé el "Equipo de Oro". Nos caracterizábamos por presentar soluciones rápidas y efectivas, una filosofía que mantengo hasta hoy.
            </p>
          </div>
        </div>

        <!-- Hito 3: Asturias -->
        <div class="relative pl-14 pb-12 group">
          <div class="absolute left-0 top-1 w-10 h-10 rounded-full bg-zinc-800 border-2 border-amber-500/50 flex items-center justify-center group-hover:border-amber-400 group-hover:bg-amber-500/10 transition-all duration-300 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M5 22h14"/><path d="M5 12h14"/><path d="M12 22V8"/><path d="M7 2l5 4 5-4"/></svg>
          </div>
          <div>
            <span class="text-amber-400/60 text-xs font-bold tracking-widest uppercase">2021 — Presente</span>
            <h3 class="text-xl font-bold text-white mt-1 mb-2">Nueva Etapa en Asturias</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Resido en Avilés, Asturias, desde hace 5 años. Aquí me especialicé en las tecnologías más modernas: FastAPI, Astro, React, y arquitecturas modulares para ofrecer soluciones de primer nivel.
            </p>
          </div>
        </div>

        <!-- Hito 4: Hoy -->
        <div class="relative pl-14 group">
          <div class="absolute left-0 top-1 w-10 h-10 rounded-full bg-amber-500/20 border-2 border-amber-400 flex items-center justify-center animate-pulse z-10">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
          </div>
          <div>
            <span class="text-amber-400 text-xs font-bold tracking-widest uppercase">Actualidad</span>
            <h3 class="text-xl font-bold text-white mt-1 mb-2">Construyendo el Futuro</h3>
            <p class="text-gray-400 text-sm leading-relaxed">
              Hoy combino toda esa experiencia para crear soluciones modulares y escalables. Cada proyecto es una oportunidad de aportar valor real usando tecnologías que marcan la diferencia.
            </p>
          </div>
        </div>
      </div>

      <!-- Columna derecha: foto + datos -->
      <div class="space-y-8">
        <div class="relative">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
            <img
              src={optimizeImage(data.image_url, 600) || optimizeImage('https://images.unsplash.com/photo-1631624220291-8f191fbdb543?q=80&w=1080', 600)}
              alt="Hernan Arango Cortes"
              class="w-full h-[400px] object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-6 left-6 text-white">
              <p class="flex items-center gap-2 text-amber-400 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {data.location}
              </p>
            </div>
          </div>
        </div>

        <!-- Cards de valores -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="p-5 bg-white/5 rounded-xl border border-white/10 hover:border-amber-500/50 hover:bg-amber-500/5 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400 mb-3"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            <h3 class="font-semibold text-white">{data.leadership_title}</h3>
            <p class="text-sm text-gray-400 mt-1">{data.leadership_desc}</p>
          </div>
          <div class="p-5 bg-white/5 rounded-xl border border-white/10 hover:border-amber-500/50 hover:bg-amber-500/5 transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400 mb-3"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <h3 class="font-semibold text-white">{data.experience_title}</h3>
            <p class="text-sm text-gray-400 mt-1">{data.experience_desc}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
