---
import type { AboutResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackAbout } from '$lib/fallback-data';

const apiData = await fetchSSR<AboutResponse>('/abouts/latest/');
const data: AboutResponse = apiData ?? fallbackAbout;
---

<section id="historia" class="py-24 bg-zinc-900 text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4">
        Mi <span class="text-amber-400">Historia</span>
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto text-lg">
        Colombiano, líder, padre de familia. Construyendo el futuro desde Asturias.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Foto -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={optimizeImage(data.image_url, 600) || optimizeImage('https://images.unsplash.com/photo-1631624220291-8f191fbdb543?q=80&w=1080', 600)}
            alt="Hernan Arango Cortes"
            class="w-full h-[450px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-6 left-6 flex items-center gap-2 text-amber-400 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Avilés, Asturias</span>
          </div>
        </div>
      </div>

      <!-- Texto -->
      <div class="space-y-6">
        <p class="text-gray-300 leading-relaxed text-lg">
          {data.description}
        </p>

        <!-- Familia (corazón de todo) -->
        <div class="p-6 rounded-2xl bg-gradient-to-r from-amber-500/10 to-red-500/5 border border-amber-500/20">
          <div class="flex items-center gap-3 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <h3 class="text-xl font-bold text-white">Mi Familia, Mi Motor</h3>
          </div>
          <p class="text-gray-300 text-sm leading-relaxed">
            Todo lo que hago, lo hago pensando en elles. Son mi razón para seguir creciendo, construyendo y soñando en grande.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 text-amber-300 text-sm">🇨🇴 Colombiano</span>
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 text-amber-300 text-sm">🏆 14+ años liderando</span>
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 text-amber-300 text-sm">🏡 Familia</span>
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 text-amber-300 text-sm">⛰️ Asturias</span>
        </div>
      </div>
    </div>
  </div>
</section>
