---
import type { AboutResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackAbout } from '$lib/fallback-data';

const apiData = await fetchSSR<AboutResponse>('/abouts/latest/');
const data: AboutResponse = apiData ?? fallbackAbout;
---

<section id="sobre-mi" class="relative bg-zinc-950 text-white overflow-hidden">
  <!-- Indicador de scroll horizontal -->
  <div class="scroll-hint absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 animate-fade-in-out pointer-events-none">
    <span class="text-[10px] uppercase tracking-[0.2em] text-amber-400/50 font-medium">Desliza →</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400/40 animate-bounce-horizontal"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </div>

  <!-- Barra de progreso horizontal -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-zinc-800 z-20">
    <div class="h-full bg-gradient-to-r from-amber-500 to-amber-300 w-0" id="scroll-progress"></div>
  </div>

  <div class="horizontal-snap flex overflow-x-auto snap-x snap-mandatory h-screen">
    <!-- Capítulo 1: Colombia -->
    <div class="snap-start shrink-0 w-screen h-screen flex items-center justify-center relative">
      <div class="max-w-2xl mx-auto px-8 text-center">
        <span class="text-amber-400/40 text-sm font-bold tracking-[0.3em] uppercase mb-4 block">2009 — 2020</span>
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-500/20 to-orange-600/20 border border-amber-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Mis Inicios en <span class="text-amber-400">Colombia</span></h2>
        <p class="text-gray-400 text-lg leading-relaxed max-w-lg mx-auto">
          Empecé mi carrera a los 18 años. Durante 11 años escalé desde posiciones iniciales hasta liderar equipos de alto rendimiento.
        </p>
        <div class="mt-8 flex items-center justify-center gap-2 text-sm text-gray-500">
          <span class="w-2 h-2 rounded-full bg-amber-400/50"></span>
          <span>14+ años de trayectoria</span>
        </div>
      </div>
    </div>

    <!-- Capítulo 2: Equipo de Oro -->
    <div class="snap-start shrink-0 w-screen h-screen flex items-center justify-center relative">
      <div class="max-w-2xl mx-auto px-8 text-center">
        <span class="text-amber-400/40 text-sm font-bold tracking-[0.3em] uppercase mb-4 block">2015 — 2020</span>
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-500/20 to-orange-600/20 border border-amber-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">El <span class="text-amber-400">Equipo de Oro</span></h2>
        <p class="text-gray-400 text-lg leading-relaxed max-w-lg mx-auto">
          Formé un equipo competitivo y ágil. Nos caracterizábamos por soluciones rápidas y efectivas, una filosofía que mantengo hoy.
        </p>
        <div class="mt-8 flex items-center justify-center gap-2 text-sm text-gray-500">
          <span class="w-2 h-2 rounded-full bg-amber-400/50"></span>
          <span>Liderazgo & trabajo en equipo</span>
        </div>
      </div>
    </div>

    <!-- Capítulo 3: MI FAMILIA (CENTRAL) -->
    <div class="snap-start shrink-0 w-screen h-screen flex items-center justify-center relative bg-gradient-to-r from-amber-900/10 via-transparent to-transparent">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(251,191,36,0.06)_0%,_transparent_60%)]"></div>
      <div class="max-w-2xl mx-auto px-8 text-center relative z-10">
        <span class="text-amber-400 text-sm font-bold tracking-[0.3em] uppercase mb-4 block">❤️ Mi Motor</span>
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-gradient-to-br from-amber-400/20 to-red-500/20 border-2 border-amber-400/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Mi <span class="text-amber-400">Familia</span>
        </h2>
        <p class="text-gray-300 text-lg leading-relaxed max-w-lg mx-auto">
          Son mi motor, mi pasión y la razón de querer continuar cada día. Todo lo que hago, lo hago pensando en elles.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <span class="px-4 py-2 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-300 text-sm font-medium">👨‍👩‍👧‍👦 Mi esposa e hijos</span>
          <span class="px-4 py-2 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-300 text-sm font-medium">🏡 Hogar en Avilés</span>
        </div>
      </div>
    </div>

    <!-- Capítulo 4: Asturias -->
    <div class="snap-start shrink-0 w-screen h-screen flex items-center justify-center relative">
      <div class="max-w-2xl mx-auto px-8 text-center">
        <span class="text-amber-400/40 text-sm font-bold tracking-[0.3em] uppercase mb-4 block">2021 — Presente</span>
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-500/20 to-orange-600/20 border border-amber-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M5 22h14"/><path d="M5 12h14"/><path d="M12 22V8"/><path d="M7 2l5 4 5-4"/></svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Nueva Vida en <span class="text-amber-400">Asturias</span></h2>
        <p class="text-gray-400 text-lg leading-relaxed max-w-lg mx-auto">
          Me mudé a Avilés con mi familia para construir un futuro mejor. Aquí me especialicé en tecnologías modernas: FastAPI, Astro, React.
        </p>
        <div class="mt-8 flex items-center justify-center gap-2 text-sm text-gray-500">
          <span class="w-2 h-2 rounded-full bg-amber-400/50"></span>
          <span>5 años construyendo el presente</span>
        </div>
      </div>
    </div>

    <!-- Capítulo 5: Hoy -->
    <div class="snap-start shrink-0 w-screen h-screen flex items-center justify-center relative">
      <div class="max-w-2xl mx-auto px-8 text-center">
        <span class="text-amber-400 text-sm font-bold tracking-[0.3em] uppercase mb-4 block">⚡ Actualidad</span>
        <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-amber-400/30 to-yellow-500/30 border border-amber-400/30 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/></svg>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Construyendo el <span class="text-amber-400">Futuro</span></h2>
        <p class="text-gray-400 text-lg leading-relaxed max-w-lg mx-auto">
          Combino toda mi experiencia para crear soluciones modulares y escalables. Cada proyecto es una oportunidad de aportar valor real.
        </p>
        <div class="mt-10 flex items-center justify-center">
          <a href="#proyectos" class="group inline-flex items-center gap-2 px-6 py-3 bg-amber-500 text-black font-bold rounded-xl hover:bg-amber-400 transition-all shadow-lg hover:shadow-amber-500/25">
            Ver mis proyectos
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Decoración: dots de navegación -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        <div class="w-2 h-2 rounded-full bg-amber-400/60"></div>
        <div class="w-2 h-2 rounded-full bg-amber-400/60"></div>
        <div class="w-3 h-3 rounded-full bg-amber-400"></div>
        <div class="w-2 h-2 rounded-full bg-amber-400/60"></div>
        <div class="w-2 h-2 rounded-full bg-amber-400/60"></div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .horizontal-snap {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-behavior: smooth;
  }
  .horizontal-snap::-webkit-scrollbar { display: none; }

  @keyframes bounce-horizontal {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }
  .animate-bounce-horizontal {
    animation: bounce-horizontal 1.5s infinite;
  }

  @keyframes fade-in-out {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }
  .animate-fade-in-out {
    animation: fade-in-out 2.5s infinite;
  }

  /* Progress bar update via JS */
  .horizontal-snap {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
  }
</style>

<script>
  (function() {
    const container = document.querySelector('.horizontal-snap');
    const progress = document.getElementById('scroll-progress');
    if (!container || !progress) return;

    container.addEventListener('scroll', () => {
      const scrollLeft = container.scrollLeft;
      const maxScroll = container.scrollWidth - container.clientWidth;
      const pct = maxScroll > 0 ? (scrollLeft / maxScroll) * 100 : 0;
      progress.style.width = pct + '%';
    });
  })();
</script>
