---
import type { AboutResponse } from '$lib/types';
import { fetchSSR, optimizeImage } from '$lib/api';
import { fallbackAbout } from '$lib/fallback-data';

const apiData = await fetchSSR<AboutResponse>('/abouts/latest/');
const data: AboutResponse = apiData ?? fallbackAbout;
---

<section id="historia" class="min-h-screen flex items-center py-24">
  <div class="w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Foto -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img src={optimizeImage(data.image_url, 600)} alt="Hernan Arango" class="w-full h-[500px] object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-6 left-6 flex items-center gap-2 text-amber-400 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Avilés, Asturias</span>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <h2 class="text-3xl md:text-5xl font-bold">
          De Colombia a <span class="text-amber-400">Asturias</span>
        </h2>
        <p class="text-gray-300 leading-relaxed text-lg">{data.description}</p>

        <div class="p-6 rounded-2xl bg-amber-500/5 border border-amber-500/15">
          <div class="flex items-center gap-3 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            <h3 class="text-lg font-bold">Mi Familia, Mi Motor</h3>
          </div>
          <p class="text-gray-400 text-sm leading-relaxed">Todo lo que hago, lo hago pensando en elles. Son mi razón para seguir creciendo.</p>
        </div>
      </div>
    </div>
  </div>
</section>
