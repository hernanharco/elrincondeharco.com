---
// RecruiterTimeline.astro — Línea de tiempo profesional interactiva

import { RECRUITER_TIMELINE } from '$lib/recruiter-data';
---

<section class="recruiter-section py-24 bg-[var(--recruiter-bg)] border-t border-[var(--recruiter-border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-cyan-400 text-xs font-medium tracking-[0.25em] uppercase mb-3">Trayectoria</p>
      <h2 class="text-3xl md:text-5xl font-bold text-white">
        Mi <span class="text-cyan-400">camino</span>
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto mt-4 text-lg">
        De aprender Visual Basic a los 10 años a administrar servidores en producción.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Línea vertical -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-cyan-500/50 via-blue-500/30 to-transparent"></div>

      {RECRUITER_TIMELINE.map((entry, i) => {
        const isLeft = i % 2 === 0;
        const typeStyles = {
          trabajo: 'border-l-blue-500 bg-blue-500/5',
          estudio: 'border-l-green-500 bg-green-500/5',
          logro: 'border-l-amber-500 bg-amber-500/5',
          hito: 'border-l-purple-500 bg-purple-500/5',
        };
        const dotColors = {
          trabajo: 'bg-blue-500',
          estudio: 'bg-green-500',
          logro: 'bg-amber-500',
          hito: 'bg-purple-500',
        };
        const borderColor = typeStyles[entry.type] || typeStyles.hito;
        const dotColor = dotColors[entry.type] || dotColors.hito;

        return (
          <div class="flex items-start gap-6 mb-12 relative md:pl-0 pl-10" data-reveal>
            <!-- Punto en la línea -->
            <div class={"absolute left-2.5 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full border-2 border-[var(--recruiter-bg)] z-10 mt-1.5 " + dotColor}></div>

            <!-- Card (alterna izquierda/derecha en desktop) -->
            <div class={"w-full md:w-[calc(50%-2rem)] " + (isLeft ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8')}>
              <div class={"p-5 rounded-xl border " + borderColor + " hover:border-cyan-500/30 transition-all duration-300"}>
                <!-- Año -->
                <span class="inline-block text-[10px] font-bold text-cyan-400 tracking-widest mb-2">{entry.year}</span>

                <!-- Título -->
                <h3 class="text-white font-bold text-base mb-1">{entry.title}</h3>
                {entry.subtitle && <p class="text-gray-500 text-xs mb-2">{entry.subtitle}</p>}

                <!-- Descripción -->
                <p class="text-gray-400 text-sm leading-relaxed">{entry.description}</p>

                <!-- Tags -->
                {entry.tags && entry.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {entry.tags.map((tag) => (
                      <span class="text-[9px] px-2 py-0.5 rounded-full bg-white/[0.04] text-gray-600 border border-white/[0.06]">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
