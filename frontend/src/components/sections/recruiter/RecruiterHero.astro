---
// RecruiterHero.astro — Hero del modo recruiter
// Nombre, rol, badge, summary y métricas técnicas

import { recruiterData } from '$lib/recruiter-data';
import { RECRUITER_METRICS } from '$lib/recruiter-data';
---

<section class="recruiter-section min-h-screen flex items-center relative overflow-hidden bg-[var(--recruiter-bg)]">
  <!-- Fondo técnico -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(6,182,212,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>
  <div class="absolute top-20 -left-20 w-96 h-96 rounded-full bg-cyan-500/5 blur-[100px]"></div>
  <div class="absolute bottom-20 -right-20 w-96 h-96 rounded-full bg-blue-500/5 blur-[100px]"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-20">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-xs font-medium mb-8 tracking-wide">
      <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
      Buscando nuevos retos
    </div>

    <!-- Nombre y rol -->
    <h1 class="text-4xl sm:text-6xl md:text-7xl font-bold text-white leading-[1.1] mb-4">
      {recruiterData.name}
    </h1>
    <p class="text-xl sm:text-2xl text-cyan-400 font-medium mb-3">
      {recruiterData.role}
    </p>
    <p class="text-gray-500 text-sm mb-8">
      {recruiterData.location} · <a href="mailto:{recruiterData.email}" class="text-cyan-400/70 hover:text-cyan-400 transition-colors">{recruiterData.email}</a>
    </p>

    <!-- Links -->
    <div class="flex gap-4 mb-12">
      <a href={recruiterData.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
      <a href={recruiterData.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-sm text-gray-300 hover:text-white transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
    </div>

    <!-- Summary -->
    <p class="text-gray-400 text-base leading-relaxed max-w-3xl mb-16">
      {recruiterData.summary}
    </p>

    <!-- Métricas técnicas -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
      {RECRUITER_METRICS.map((m) => (
        <div class="text-center p-4 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:border-cyan-500/20 transition-all duration-300">
          <div class="text-2xl md:text-3xl font-bold text-cyan-400 mb-1">{m.value}</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">{m.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
