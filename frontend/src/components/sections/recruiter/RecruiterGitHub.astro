---
// RecruiterGitHub.astro — Dashboard GitHub real (client-side fetch)
// Muestra estrellas, repos, lenguajes y actividad en vivo.
---

<section class="recruiter-section py-24 bg-[var(--recruiter-bg)] border-t border-[var(--recruiter-border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-cyan-400 text-xs font-medium tracking-[0.25em] uppercase mb-3">GitHub</p>
      <h2 class="text-3xl md:text-5xl font-bold text-white">
        Código en <span class="text-cyan-400">vivo</span>
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto mt-4 text-lg">
        Datos reales desde mi GitHub. Se actualizan automáticamente.
      </p>
    </div>

    <!-- Dashboard grid -->
    <div id="github-dashboard" class="grid md:grid-cols-4 gap-4 mb-8">
      <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.06] text-center">
        <div class="text-2xl font-bold text-cyan-400 mb-1"><span id="gh-repos">—</span></div>
        <div class="text-xs text-gray-500 uppercase tracking-wider">Repositorios</div>
      </div>
      <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.06] text-center">
        <div class="text-2xl font-bold text-amber-400 mb-1"><span id="gh-stars">—</span></div>
        <div class="text-xs text-gray-500 uppercase tracking-wider">Estrellas ⭐</div>
      </div>
      <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.06] text-center">
        <div class="text-2xl font-bold text-green-400 mb-1"><span id="gh-forks">—</span></div>
        <div class="text-xs text-gray-500 uppercase tracking-wider">Forks</div>
      </div>
      <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.06] text-center">
        <div class="text-2xl font-bold text-purple-400 mb-1"><span id="gh-langs">—</span></div>
        <div class="text-xs text-gray-500 uppercase tracking-wider">Lenguajes</div>
      </div>
    </div>

    <!-- Top repos -->
    <div id="gh-repos-list" class="space-y-3">
      <p class="text-gray-500 text-sm text-center">Cargando datos desde GitHub...</p>
    </div>

    <div class="text-center mt-8">
      <a href="https://github.com/hernanharco" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-cyan-400 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        Ver todos los repos en GitHub →
      </a>
    </div>
  </div>
</section>

<script>
  (async function () {
    try {
      const res = await fetch("https://api.github.com/users/hernanharco/repos?sort=updated&per_page=30");
      if (!res.ok) throw new Error("GitHub API error");
      const repos = await res.json();

      // Stats
      const totalStars = repos.reduce((sum, r) => sum + r.stargazers_count, 0);
      const totalForks = repos.reduce((sum, r) => sum + r.forks_count, 0);
      const languages = [...new Set(repos.filter(r => r.language).map(r => r.language))];

      document.getElementById("gh-repos").textContent = repos.length;
      document.getElementById("gh-stars").textContent = totalStars;
      document.getElementById("gh-forks").textContent = totalForks;
      document.getElementById("gh-langs").textContent = languages.length;

      // Top repos (ordenados por estrellas)
      const topRepos = repos.sort((a, b) => b.stargazers_count - a.stargazers_count).slice(0, 6);
      const listEl = document.getElementById("gh-repos-list");
      listEl.innerHTML = topRepos.map(repo => `
        <a href="${repo.html_url}" target="_blank" rel="noopener noreferrer" class="block p-4 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-cyan-500/20 hover:bg-white/[0.04] transition-all duration-300">
          <div class="flex items-center justify-between mb-1">
            <span class="text-white font-semibold text-sm">${repo.name}</span>
            <span class="text-xs text-amber-400">${repo.stargazers_count > 0 ? repo.stargazers_count + ' ⭐' : ''}</span>
          </div>
          <p class="text-gray-500 text-xs leading-relaxed">${repo.description || 'Sin descripción'}</p>
          <div class="flex items-center gap-3 mt-2 text-[10px] text-gray-600">
            ${repo.language ? `<span>🔵 ${repo.language}</span>` : ''}
            <span>🔀 ${repo.forks_count}</span>
            ${repo.updated_at ? `<span>📅 ${new Date(repo.updated_at).toLocaleDateString('es')}</span>` : ''}
          </div>
        </a>
      `).join("");
    } catch (e) {
      document.getElementById("gh-repos-list").innerHTML = '<p class="text-gray-500 text-sm text-center">No se pudieron cargar los datos de GitHub. <a href="https://github.com/hernanharco" class="text-cyan-400 hover:underline">Ver perfil →</a></p>';
    }
  })();
</script>
