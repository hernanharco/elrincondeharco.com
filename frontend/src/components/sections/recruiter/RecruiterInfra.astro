---
// RecruiterInfra.astro — Servidores, red e infraestructura

import { RECRUITER_SERVERS } from '$lib/recruiter-data';
---

<section class="recruiter-section py-24 bg-[var(--recruiter-bg)] border-t border-[var(--recruiter-border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-cyan-400 text-xs font-medium tracking-[0.25em] uppercase mb-3">Infraestructura</p>
      <h2 class="text-3xl md:text-5xl font-bold text-white">
        Mis <span class="text-cyan-400">servidores</span>
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto mt-4 text-lg">
        No solo codeo: administro infraestructura real en producción.
      </p>
    </div>

    <!-- Servidores -->
    <div class="grid md:grid-cols-2 gap-6 mb-16">
      {RECRUITER_SERVERS.map((server) => (
        <div class="p-6 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-cyan-500/20 transition-all duration-300">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">{server.name}</h3>
              <p class="text-xs text-gray-500">{server.provider}</p>
            </div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Especificaciones</span>
              <span class="text-gray-300">{server.specs}</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Sistema</span>
              <span class="text-gray-300">{server.os}</span>
            </div>
            {server.uptime && (
              <div class="flex justify-between text-sm">
                <span class="text-gray-500">Uptime</span>
                <span class="text-green-400">{server.uptime}</span>
              </div>
            )}
          </div>
          <div>
            <p class="text-xs text-gray-600 uppercase tracking-wider mb-2">Servicios activos</p>
            <div class="flex flex-wrap gap-1.5">
              {server.services.map((svc) => (
                <span class="text-[10px] px-2 py-0.5 rounded-md bg-cyan-500/5 text-cyan-400/80 border border-cyan-500/10">
                  {svc}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Diagrama de red -->
    <div class="p-8 rounded-xl bg-white/[0.02] border border-white/[0.06]">
      <h3 class="text-lg font-bold text-white mb-6 text-center">Arquitectura de Red</h3>
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-8 text-sm">
        <!-- Clientes -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-2 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <p class="text-gray-400 text-xs">Usuarios</p>
        </div>

        <svg class="w-6 h-6 text-gray-600 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        <svg class="w-6 h-6 text-gray-600 rotate-90 md:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>

        <!-- Cloudflare -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-2 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p class="text-gray-400 text-xs">Cloudflare Tunnel</p>
        </div>

        <svg class="w-6 h-6 text-gray-600 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        <svg class="w-6 h-6 text-gray-600 rotate-90 md:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>

        <!-- Servidores -->
        <div class="flex gap-4">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-2 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
            </div>
            <p class="text-gray-400 text-xs">Hetzner</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-2 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
              <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
            </div>
            <p class="text-gray-400 text-xs">Netcup</p>
          </div>
        </div>
      </div>

      <!-- Labels de conexión -->
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">🔒 WireGuard VPN</span>
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">🔗 Tailscale Mesh</span>
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">🐳 Docker</span>
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">🔀 Traefik</span>
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">📊 Netdata</span>
        <span class="text-[10px] px-2.5 py-1 rounded-full bg-white/[0.03] text-gray-500 border border-white/[0.06]">🤖 Ollama</span>
      </div>
    </div>
  </div>
</section>
