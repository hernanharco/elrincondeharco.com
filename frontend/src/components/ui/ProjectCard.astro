---
import type { ProjectResponse } from '$lib/types';
import { optimizeImage } from '$lib/api';
import TiltCard from '../effects/TiltCard.astro';

export interface Props {
  project: ProjectResponse;
}

const { project } = Astro.props;

const iconPaths: Record<string, string> = {
  layers: '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  calendar: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>',
  coffee: '<path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/>',
  'shopping-bag': '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>',
  'building-2': '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>',
  search: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  bot: '<path d="M12 8V4m0 0a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v4m8-4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4"/><path d="M2 21h20"/><rect x="2" y="8" width="20" height="8" rx="2"/><circle cx="8" cy="14" r="1.5" fill="currentColor"/><circle cx="16" cy="14" r="1.5" fill="currentColor"/><path d="M10 10h4"/>',
};

function pascalToKebab(name: string): string {
  return name
    .replace(/([A-Z])/g, (m, l, o) => (o > 0 ? '-' + l.toLowerCase() : l.toLowerCase()))
    .replace(/(\d+)/g, '-$1')
    .replace(/--+/g, '-')
    .replace(/-+$/, '');
}

function getIconSvg(iconName: string, size: number = 24): string {
  if (!iconName) iconName = 'layers';
  const kebab = pascalToKebab(iconName);
  const renames: Record<string, string> = { globe: 'earth', 'globe-icon': 'earth' };
  const resolved = renames[kebab] || kebab;
  const path = iconPaths[resolved] || iconPaths['layers'];
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`;
}
---

<TiltCard>
<div
  class="group bg-black border border-white/10 rounded-2xl overflow-hidden hover:border-amber-500/30 transition-shadow duration-500 hover:shadow-[0_0_30px_-5px_rgba(251,191,36,0.15)] flex flex-col h-full"
>
  <div class="relative h-48 overflow-hidden">
    {project.image_url ? (
      <>
        <div class="absolute inset-0 bg-gradient-to-tr {project.color} opacity-60 z-10"></div>
        <img
          src={optimizeImage(project.image_url, 600)}
          alt={project.title}
          class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
          loading="lazy"
        />
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br {project.color}">
        <span class="text-white/30 scale-[4]">{getIconSvg(project.icon_name, 48)}</span>
      </div>
    )}
    <div class="absolute top-4 right-4 z-20 bg-black/50 backdrop-blur-md p-2 rounded-lg border border-white/10 text-white">
      <span set:html={getIconSvg(project.icon_name, 20)} />
    </div>
  </div>

  <div class="p-6 flex-1 flex flex-col">
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-amber-400 transition-colors">
      {project.title}
    </h3>
    <p class="text-gray-400 mb-6 text-sm leading-relaxed flex-1">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {project.tags.map(tag => (
        <span class="px-3 py-1 text-xs font-medium rounded-full bg-white/5 border border-white/10 text-gray-300">{tag}</span>
      ))}
    </div>

    <div class="flex items-center gap-4 pt-4 border-t border-white/5 mt-auto">
      {project.demo_url && (
        <a
          href={project.demo_url}
          target="_blank"
          class="flex items-center gap-2 text-sm font-medium text-white hover:text-amber-400 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          Ver Demo
        </a>
      )}
      {project.github_url && (
        <a
          href={project.github_url}
          target="_blank"
          class="flex items-center gap-2 text-sm font-medium text-gray-400 hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          Código
        </a>
      )}
    </div>
  </div>
</TiltCard>
