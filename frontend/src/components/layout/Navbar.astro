---
const links = [
  { name: 'Inicio', href: '#inicio' },
  { name: 'Proyectos', href: '#proyectos' },
  { name: 'Historia', href: '#historia' },
  { name: 'Contacto', href: '#contacto' },
];
---

<nav class="fixed w-full z-50 bg-black/80 backdrop-blur-md border-b border-white/10 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <input type="checkbox" id="menu-toggle" class="hidden peer" />

    <div class="flex items-center justify-between h-16">
      <a href="#inicio" class="text-xl font-bold bg-gradient-to-r from-amber-400 to-yellow-600 bg-clip-text text-transparent hover:from-amber-300 hover:to-yellow-500 transition-all duration-300">
        HAC
      </a>

      <div class="hidden md:flex items-center gap-1">
        {links.map(link => (
          <a href={link.href} class="px-3 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-amber-400 hover:bg-white/5 transition-all duration-300">{link.name}</a>
        ))}
        <a href="#contacto" class="ml-3 px-4 py-2 bg-amber-500 hover:bg-amber-400 text-black text-sm font-bold rounded-xl transition-all duration-300 shadow-lg hover:shadow-amber-500/25 active:scale-95">
          Trabajemos
        </a>
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <a href="#contacto" class="px-3 py-1.5 bg-amber-500 text-black text-xs font-bold rounded-lg">Trabajemos</a>
        <label for="menu-toggle" class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/10 cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </label>
      </div>
    </div>

    <div id="mobile-menu" class="hidden peer-checked:block md:hidden">
      <div class="px-2 pt-2 pb-4 space-y-1 bg-black/95 backdrop-blur-xl border-t border-white/10 rounded-b-2xl">
        {links.map(link => (
          <a href={link.href} onclick="document.getElementById('menu-toggle').checked = false" class="block px-4 py-3 rounded-xl text-base font-medium text-gray-300 hover:text-amber-400 hover:bg-white/5 transition-colors">{link.name}</a>
        ))}
      </div>
    </div>
  </div>
</nav>
